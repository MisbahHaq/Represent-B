@model RepresentWeb.Controllers.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="w-100 min-vh-100 d-flex text-white" style="background-color: #0d0d0d; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; overflow-x: hidden;">
    <div class="row g-0 w-100 min-vh-100">
        
        <div class="col-md-6 d-none d-md-flex flex-column justify-content-between p-5 position-relative" style="background-color: #050505; border-right: 1px solid #151515;">
            <div class="fs-5 fw-semibold tracking-wide" style="color: #ffffff; letter-spacing: -0.5px;">
                Represent<span style="font-size: 0.6rem; vertical-align: super; margin-left: 2px;">®</span>
            </div>

            <div class="position-absolute top-50 start-50 translate-middle w-100 h-100 d-flex align-items-center justify-content-center opacity-75" style="pointer-events: none;">
                <div class="position-absolute w-100" style="height: 1px; background: linear-gradient(90deg, transparent, #222 20%, #222 80%, transparent);"></div>
                <div class="position-absolute h-100" style="width: 1px; background: linear-gradient(180deg, transparent, #222 20%, #222 80%, transparent);"></div>
                <div class="position-absolute w-100" style="height: 1px; background: linear-gradient(90deg, transparent, #151515 30%, #151515 70%, transparent); transform: rotate(45deg);"></div>
                <div class="position-absolute w-100" style="height: 1px; background: linear-gradient(90deg, transparent, #151515 30%, #151515 70%, transparent); transform: rotate(-45deg);"></div>

                <svg width="140" height="140" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <line x1="50" y1="5" x2="50" y2="95" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
                    <line x1="5" y1="50" x2="95" y2="50" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
                    <line x1="18.2" y1="18.2" x2="81.8" y2="81.8" stroke="white" stroke-width="2" stroke-linecap="round"/>
                    <line x1="18.2" y1="81.8" x2="81.8" y2="18.2" stroke="white" stroke-width="2" stroke-linecap="round"/>
                    <circle cx="50" cy="50" r="7" fill="#050505" stroke="white" stroke-width="2.5"/>
                </svg>
            </div>

            <div style="font-size: 0.68rem; color: #444; z-index: 2;">
                © Represent 2026. All rights reserved.
            </div>
        </div>

        <div class="col-12 col-md-6 d-flex flex-column justify-content-between p-4 p-sm-5 position-relative" style="background: radial-gradient(circle at 70% 30%, #141414 0%, #0d0d0d 100%);">
            
            <div class="d-flex justify-content-between align-items-center w-100 mb-5 mb-md-0">
                <div class="d-block d-md-none fs-6 fw-semibold text-white">Represent<span style="font-size: 0.5rem; vertical-align: super;">®</span></div>
                <div class="ms-auto">
                    <a asp-action="SignUp" class="text-decoration-none" style="font-size: 0.75rem; color: #888; transition: color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#888'">Create an account</a>
                </div>
            </div>

            <div class="w-100 my-auto mx-auto" style="max-width: 380px;">
                <h1 class="mb-5 fw-light tracking-tight" style="font-size: 2.8rem; color: #fff; letter-spacing: -1px;">Login</h1>

                <form asp-action="Login" method="post" autocomplete="off" class="d-flex flex-column gap-4">
                    <div asp-validation-summary="All" class="text-danger" style="font-size: 0.78rem;"></div>

                    <div class="position-relative border-bottom border-secondary pb-2" style="border-color: #222 !important;">
                        <label asp-for="Email" class="d-block text-uppercase tracking-wider mb-1" style="font-size: 0.65rem; color: #666; font-weight: 600;">Email</label>
                        <input asp-for="Email" class="w-100 bg-transparent border-0 p-0 text-white" placeholder="mark.johnson@gmail.com" autocomplete="email" style="outline: none; font-size: 0.95rem; font-weight: 300; letter-spacing: 0.3px;" />
                        <span asp-validation-for="Email" class="text-danger d-block mt-1" style="font-size: 0.72rem;"></span>
                    </div>

                    <div class="position-relative border-bottom border-secondary pb-2" style="border-color: #222 !important;">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label asp-for="Password" class="text-uppercase tracking-wider m-0" style="font-size: 0.65rem; color: #666; font-weight: 600;">Password</label>
                            <a asp-action="ForgotPassword" class="text-decoration-none" style="font-size: 0.72rem; color: #555; transition: color 0.2s;" onmouseover="this.style.color='#888'" onmouseout="this.style.color='#555'">Forgot?</a>
                        </div>
                        <input asp-for="Password" class="w-100 bg-transparent border-0 p-0 text-white" type="password" placeholder="••••••••••••" autocomplete="current-password" style="outline: none; font-size: 0.95rem; font-weight: 300; letter-spacing: 2px;" />
                        <span asp-validation-for="Password" class="text-danger d-block mt-1" style="font-size: 0.72rem;"></span>
                    </div>

                    <div class="d-flex align-items-center mt-2">
                        <label class="d-flex align-items-center gap-2 m-0" style="cursor: pointer; font-size: 0.78rem; color: #888; font-weight: 300;">
                            <input asp-for="RememberMe" type="checkbox" style="accent-color: #ffffff; width: 15px; height: 15px; cursor: pointer; background-color: transparent;" />
                            <span>Remember me</span>
                        </label>
                    </div>

                    <div class="d-flex justify-content-end mt-4 position-relative">
                        <button type="submit" class="btn d-flex align-items-center justify-content-center p-0 rounded-circle" 
                                style="width: 64px; height: 64px; background-color: #ffffff; color: #000000; border: none; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; box-shadow: 0 8px 24px rgba(0,0,0,0.4); transition: transform 0.2s, background-color 0.2s;"
                                onmouseover="this.style.transform='scale(1.05)'; this.style.backgroundColor='#f0f0f0';" 
                                onmouseout="this.style.transform='scale(1)'; this.style.backgroundColor='#ffffff';">
                            SIGN IN
                        </button>
                    </div>
                </form>
            </div>

            <div class="d-block d-md-none mt-5 text-center" style="font-size: 0.65rem; color: #333;">
                © Represent 2026.
            </div>
            <div class="d-none d-md-block" style="height: 20px;"></div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}