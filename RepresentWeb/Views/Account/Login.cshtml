@model representweb.Controllers.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="section-spacer bg-white">
    <div class="container-fluid" style="max-width: 480px; padding: 0 clamp(1.5rem, 4vw, 4rem); margin: 0 auto;">

        <div class="text-center mb-5 animate-fade-in">
            <p class="text-caption" style="color: #999;">Account</p>
            <h1 class="text-heading text-primary m-0 mt-2" style="font-size: 1.4rem;">Login</h1>
            <div style="width: 30px; height: 1px; background: #1a1a1a; margin: 1.2rem auto 0;"></div>
        </div>

        <div class="animate-fade-in animate-delay-1">
            <form asp-action="Login" method="post" autocomplete="off">
                <div asp-validation-summary="All" class="mb-4 text-danger" style="font-size: 0.78rem; font-weight: 300;"></div>

                <div class="mb-4">
                    <label asp-for="Email" class="text-caption d-block mb-2" style="color: #999;">Email Address</label>
                    <input asp-for="Email" class="form-minimal" placeholder="your@email.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="text-caption d-block mb-2" style="color: #999;">Password</label>
                    <input asp-for="Password" class="form-minimal" type="password" placeholder="••••••••" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>

                <div class="mb-5 d-flex align-items-center gap-3">
                    <input asp-for="RememberMe" class="border-0 bg-transparent"
                           style="accent-color: #1a1a1a; width: 16px; height: 16px; cursor: pointer;" type="checkbox" />
                    <label asp-for="RememberMe" class="mb-0"
                           style="font-size: 0.78rem; font-weight: 300; color: #666; cursor: pointer;">
                        Remember me
                    </label>
                </div>

                <button type="submit" class="btn-minimal btn-filled w-100 py-3 mb-4">
                    Sign In
                </button>

                <div class="text-center" style="font-size: 0.78rem; font-weight: 300; color: #888;">
                    <p class="mb-2">
                        <a asp-action="SignUp"
                           class="hover-reveal"
                           style="color: #1a1a1a; text-decoration: none; border-bottom: 1px solid #1a1a1a; padding-bottom: 2px;">
                            Create an account
                        </a>
                    </p>
                    <p>
                        <a asp-action="ForgotPassword" class="hover-fade" style="color: #bbb; text-decoration: none;">
                            Forgot password?
                        </a>
                    </p>
                </div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
