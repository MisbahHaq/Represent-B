@model representweb.Models.ProfileViewModel

@{
    ViewData["Title"] = "My Account";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="section-spacer bg-white">
    <div class="container-fluid" style="max-width: 1300px; padding: 0 clamp(1.5rem, 4vw, 4rem);">

        <!-- Header -->
        <div class="mb-6 animate-fade-in">
            <p class="text-caption" style="color: #999;">Account</p>
            <div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mt-3">
                <h1 class="text-heading text-primary m-0" style="font-size: 1.4rem;">@Model.UserName</h1>
                <div class="d-flex gap-3">
                    <a asp-action="UpdateUsername" asp-controller="Account"
                       class="btn-minimal text-only">Change Username</a>
                    <a asp-action="UpdateAddress" asp-controller="Account"
                       class="btn-minimal text-only">Change Address</a>
                </div>
            </div>
            <div style="width: 30px; height: 1px; background: #1a1a1a; margin-top: 1.2rem;"></div>
        </div>

        <div class="row gx-5 gy-5">

            <!-- Main Content -->
            <div class="col-12 col-lg-8">

                <div class="animate-fade-in animate-delay-1">

                    <p class="text-subheading mb-5" style="color: #999; font-size: 0.72rem;">Orders</p>

                    @foreach (var status in new[] { "Pending", "Out for Delivery", "Delivered", "Cancelled" })
                    {
                        var orders = Model.Orders.Where(o => o.Status == status).ToList();
                        <div class="mb-6">
                            <p class="text-heading mb-4"
                               style="font-size: 0.85rem; letter-spacing: 0.12em; text-transform: uppercase;">
                                @status
                                @if (orders.Any())
                                {
                                    <span style="font-weight: 200; color: #bbb;">(@orders.Count)</span>
                                }
                            </p>

                            @if (orders.Any())
                            {
                                <div class="row g-3 gx-0">
                                    @foreach (var order in orders)
                                    {
                                        <div class="col-12" style="padding: 1.4rem 0; border-bottom: 1px solid #f0f0ee;">
                                            <div class="row align-items-center g-3">
                                                <div class="col-12 col-md-4">
                                                    <p style="font-size: 0.82rem; font-weight: 400; letter-spacing: 0.04em; text-transform: uppercase;">
                                                        Order #@order.Id
                                                    </p>
                                                    <p style="font-size: 0.72rem; font-weight: 300; color: #999; margin-top: 0.15rem;">
                                                        @order.OrderDate.ToString("MMM dd, yyyy")
                                                    </p>
                                                </div>
                                                <div class="col-12 col-md-4">
                                                    <div class="d-flex flex-wrap gap-3">
                                                        @foreach (var item in order.Items)
                                                        {
                                                            <div class="img-container"
                                                                 style="width: 42px; height: 52px; aspect-ratio: 3/4; background: #f7f7f5;">
                                                                <img src="@item.ImageUrl"
                                                                     alt="@item.ProductName"
                                                                     style="object-fit: contain; padding: 0.25rem;" />
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                                <div class="col-6 col-md-2 text-start text-md-center">
                                                    <p style="font-size: 0.78rem; font-weight: 300; color: #666;">
                                                        @order.Items.Sum(i => i.Quantity) item(s)
                                                    </p>
                                                </div>
                                                <div class="col-6 col-md-2 text-end">
                                                    <p style="font-size: 0.88rem; font-weight: 400; letter-spacing: 0.03em;">
                                                        Rs @order.TotalAmount.ToString("N2")
                                                    </p>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p style="font-size: 0.78rem; font-weight: 300; color: #bbb; font-style: italic;">
                                    No orders.
                                </p>
                            }
                        </div>
                    }

                </div>

                <!-- Recently Viewed -->
                <div class="animate-fade-in animate-delay-2 mt-6">
                    <p class="text-subheading mb-5" style="color: #999; font-size: 0.72rem;">Recently Viewed</p>

                    @if (Model.RecentlyViewed.Any())
                    {
                        <div class="row gx-4 gy-5">
                            @foreach (var product in Model.RecentlyViewed)
                            {
                                <div class="col-6 col-md-3">
                                    <a asp-action="Details" asp-controller="Products" asp-route-id="@product.Id"
                                       class="d-block text-decoration-none" style="color: inherit;">
                                        <div class="img-container aspect-square mb-3" style="background: #f7f7f5;">
                                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                                            {
                                                <img src="@product.ImageUrl"
                                                     alt="@product.Name"
                                                     style="object-fit: contain; padding: 0.8rem;" />
                                            }
                                        </div>
                                        <p class="m-0"
                                           style="font-size: 0.75rem; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase;">
                                            @product.Name
                                        </p>
                                        <p class="m-0 mt-1" style="font-size: 0.73rem; font-weight: 300; color: #999;">
                                            Rs @product.Price.ToString("N2")
                                        </p>
                                    </a>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p style="font-size: 0.78rem; font-weight: 300; color: #bbb; font-style: italic;">
                            No recently viewed products.
                        </p>
                    }
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-12 col-lg-3 offset-lg-1" style="padding-top: 0.5rem;">
                <div class="animate-fade-in animate-delay-3">
                    <p class="text-caption mb-4" style="color: #999;">Profile</p>

                    <div class="mb-5">
                        <p style="font-size: 0.85rem; font-weight: 300; color: #666;">
                            @Model.UserEmail
                        </p>
                        @if (!string.IsNullOrEmpty(Model.UserAddress))
                        {
                            <p style="font-size: 0.78rem; font-weight: 300; color: #bbb; margin-top: 0.3rem;">
                                @Model.UserAddress
                            </p>
                        }
                    </div>

                    <hr class="divider thin">

                    <nav class="list-unstyled" style="font-size: 0.78rem; font-weight: 300; line-height: 2.4;">
                        <li>
                            <a class="d-block hover-fade"
                               asp-action="Logout" asp-controller="Account"
                               style="color: #1a1a1a; text-decoration: none; text-transform: uppercase; letter-spacing: 0.12em;">
                                Logout
                            </a>
                        </li>
                    </nav>
                </div>
            </div>

        </div>
    </div>
</div>
