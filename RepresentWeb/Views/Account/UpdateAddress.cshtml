@model representweb.Controllers.UpdateAddressViewModel

@{
    ViewData["Title"] = "Update Address";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h3 class="text-center">Update Address</h3>
                </div>
                <div class="card-body">
                    <form asp-action="UpdateAddress" method="post">
                        <div class="mb-3">
                            <label asp-for="Address" class="form-label"></label>
                            <input asp-for="Address" class="form-control" />
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">Update</button>
                        </div>
                    </form>
                    <div class="text-center mt-3">
                        <a asp-action="Profile" asp-controller="Account" class="btn btn-outline-link">Cancel</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>