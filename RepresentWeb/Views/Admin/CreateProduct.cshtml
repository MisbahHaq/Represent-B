@model RepresentWeb.Models.Product
@{
    ViewData["Title"] = "Add Product";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container my-5" style="max-width: 600px;">
    <h4 class="text-uppercase tracking-wider mb-5 text-secondary fw-light">New Product</h4>

    <form asp-action="CreateProduct" method="post" class="text-dark" id="productForm">
        <input type="hidden" asp-for="ImageUrls" id="ImageUrlsCombined" />
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-4"></div>

        <div class="mb-4">
            <input asp-for="Name" class="form-control bg-transparent text-dark border-0 border-bottom border-dark rounded-0 px-0 shadow-none" placeholder="Product Name">
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <textarea asp-for="Description" class="form-control bg-transparent text-dark border-0 border-bottom border-dark rounded-0 px-0 shadow-none" rows="1" placeholder="Description"></textarea>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <input asp-for="Price" class="form-control bg-transparent text-dark border-0 border-bottom border-dark rounded-0 px-0 shadow-none" type="number" step="0.01" placeholder="Price ($)">
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <input asp-for="Stock" class="form-control bg-transparent text-dark border-0 border-bottom border-dark rounded-0 px-0 shadow-none" type="number" placeholder="Stock Qty">
            </div>
            <div class="col-md-4">
                <select asp-for="Gender" class="form-select bg-transparent text-dark border-0 border-bottom border-dark rounded-0 px-0 shadow-none">
                    <option value="" class="bg-white text-dark">Unisex</option>
                    <option value="Men" class="bg-white text-dark">Men</option>
                    <option value="Women" class="bg-white text-dark">Women</option>
                </select>
            </div>
        </div>

        <div class="mb-4">
            <input asp-for="ImageUrl" class="form-control bg-transparent text-dark border-0 border-bottom border-dark rounded-0 px-0 shadow-none" placeholder="Main Image URL">
        </div>

        <div class="row g-3 mb-4 row-cols-2 row-cols-md-3">
            <div class="col">
                <input type="text" name="ImageUrls[0]" class="form-control form-control-sm bg-transparent text-dark border-0 border-bottom border-dark rounded-0 px-0 shadow-none" placeholder="Image URL 1">
            </div>
            <div class="col">
                <input type="text" name="ImageUrls[1]" class="form-control form-control-sm bg-transparent text-dark border-0 border-bottom border-dark rounded-0 px-0 shadow-none" placeholder="Image URL 2">
            </div>
            <div class="col">
                <input type="text" name="ImageUrls[2]" class="form-control form-control-sm bg-transparent text-dark border-0 border-bottom border-dark rounded-0 px-0 shadow-none" placeholder="Image URL 3">
            </div>
            <div class="col">
                <input type="text" name="ImageUrls[3]" class="form-control form-control-sm bg-transparent text-dark border-0 border-bottom border-dark rounded-0 px-0 shadow-none" placeholder="Image URL 4">
            </div>
            <div class="col col-md-12">
                <input type="text" name="ImageUrls[4]" class="form-control form-control-sm bg-transparent text-dark border-0 border-bottom border-dark rounded-0 px-0 shadow-none" placeholder="Image URL 5">
            </div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-6">
                <input asp-for="Tags" class="form-control bg-transparent text-dark border-0 border-bottom border-dark rounded-0 px-0 shadow-none" placeholder="Tags (comma separated)">
            </div>
            <div class="col-md-6">
                <input asp-for="Colors" class="form-control bg-transparent text-dark border-0 border-bottom border-dark rounded-0 px-0 shadow-none" placeholder="Colors (comma separated)">
            </div>
        </div>

        <div class="pt-3 d-flex align-items-center">
            <button type="submit" class="btn btn-sm btn-dark rounded-0 px-4 me-3">Create</button>
            <a asp-action="Products" class="text-secondary small text-decoration-none hover-dark">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('productForm');
            const combined = document.getElementById('ImageUrlsCombined');
            const inputs = Array.from(document.querySelectorAll('input[name^="ImageUrls["]'));

            form.addEventListener('submit', function () {
                combined.value = inputs
                    .map(input => input.value.trim())
                    .filter(value => value.length > 0)
                    .join(', ');
            });
        });
    </script>
    <partial name="_ValidationScriptsPartial" />
}