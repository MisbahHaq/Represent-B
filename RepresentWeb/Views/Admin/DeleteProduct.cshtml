@model representweb.Models.Product
@{
    ViewData["Title"] = "Delete Product";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2 class="text-uppercase mb-4">Delete Product</h2>

    <div class="card bg-dark text-white">
        <div class="card-body">
            <h4 class="text-danger">Are you sure you want to delete this product?</h4>
            
            <div class="row mt-4">
                <div class="col-md-4">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid">
                    }
                </div>
                <div class="col-md-8">
                    <h5>@Model.Name</h5>
                    <p class="text-secondary">@Model.Description</p>
                    <p><strong>Price:</strong> $@Model.Price</p>
                    <p><strong>Stock:</strong> @Model.Stock</p>
                </div>
            </div>

            <form asp-action="DeleteProduct" method="post" class="mt-4">
                <input type="hidden" asp-for="Id">
                <button type="submit" class="btn btn-danger">Delete Product</button>
                <a asp-action="Products" class="btn btn-outline-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>