@model representweb.Models.Product
@{
    ViewData["Title"] = "Edit Product";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2 class="text-uppercase mb-4">Edit Product</h2>

    <div class="card bg-dark text-white">
        <div class="card-body">
            <form asp-action="EditProduct" method="post">
                <input type="hidden" asp-for="Id">
                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Product Name</label>
                    <input asp-for="Name" class="form-control bg-dark text-white border-secondary">
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control bg-dark text-white border-secondary" rows="3"></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="Price" class="form-label">Price</label>
                    <input asp-for="Price" class="form-control bg-dark text-white border-secondary" type="number" step="0.01">
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Stock" class="form-label">Stock Quantity</label>
                    <input asp-for="Stock" class="form-control bg-dark text-white border-secondary" type="number">
                </div>

                <div class="mb-3">
                    <label asp-for="Gender" class="form-label">Gender</label>
                    <select asp-for="Gender" class="form-select bg-dark text-white border-secondary">
                        <option value="">Unisex</option>
                        <option value="Men">Men</option>
                        <option value="Women">Women</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label asp-for="ImageUrl" class="form-label">Main Image URL</label>
                    <input asp-for="ImageUrl" class="form-control bg-dark text-white border-secondary" placeholder="/images/product.jpg">
                </div>

                <div class="mb-3">
                    <label asp-for="ImageUrls" class="form-label">Additional Image URLs (comma separated)</label>
                    <input asp-for="ImageUrls" class="form-control bg-dark text-white border-secondary" placeholder="/images/1.jpg, /images/2.jpg">
                </div>

                <div class="mb-3">
                    <label asp-for="Tags" class="form-label">Tags (comma separated)</label>
                    <input asp-for="Tags" class="form-control bg-dark text-white border-secondary" placeholder="new, sale, popular">
                </div>

                <button type="submit" class="btn btn-light">Save Changes</button>
                <a asp-action="Products" class="btn btn-outline-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}