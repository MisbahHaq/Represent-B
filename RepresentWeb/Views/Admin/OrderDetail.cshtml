@model RepresentWeb.Models.Order
@{
    ViewData["Title"] = "Order #" + Model.Id;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4 px-3 px-sm-4">
    <div class="d-flex justify-content-between align-items-md-center flex-column flex-md-row gap-3 mb-4">
        <h2 class="text-uppercase mb-0 admin-page-heading">Order #@Model.Id</h2>
        <div class="d-flex gap-2 admin-page-actions">
            <a asp-action="Dashboard" class="btn btn-outline-secondary">Back to Dashboard</a>
            <a asp-action="Orders" class="btn btn-outline-secondary">Back to Orders</a>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12 col-md-6">
            <div class="card bg-dark text-white">
                <div class="card-body">
                    <h5 class="card-title text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.1em; color: #888;">Customer Information</h5>
                    <p class="mb-1"><strong>Email:</strong> @Model.UserEmail</p>
                    <p class="mb-1"><strong>Phone:</strong> @(string.IsNullOrEmpty(Model.PhoneNumber) ? "N/A" : Model.PhoneNumber)</p>
                    <p class="mb-0"><strong>Address:</strong> @(string.IsNullOrEmpty(Model.Address) ? "N/A" : Model.Address)</p>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="card bg-dark text-white">
                <div class="card-body">
                    <h5 class="card-title text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.1em; color: #888;">Order Information</h5>
                    <p class="mb-1"><strong>Date:</strong> @Model.OrderDate.ToString("MMMM dd, yyyy — hh:mm tt")</p>
                    <p class="mb-1"><strong>Status:</strong> <span class="badge bg-@(Model.Status == "Order Received" ? "light text-dark" : Model.Status == "Pending" ? "warning" : Model.Status == "Out for Delivery" ? "info" : Model.Status == "Delivered" ? "success" : "secondary")">@Model.Status</span></p>
                    <p class="mb-1"><strong>Delivery:</strong> @(Model.DeliveryMethod ?? "")</p>
                    <p class="mb-1"><strong>Payment:</strong> @(Model.PaymentMethod ?? "")</p>
                    <p class="mb-0"><strong>Total:</strong> Rs @Model.TotalAmount.ToString("N2")</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card bg-dark text-white">
        <div class="card-body">
            <h5 class="card-title text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.1em; color: #888; margin-bottom: 1.5rem;">Order Items (@Model.Items.Count)</h5>
            <div class="table-responsive">
                <table class="table table-dark table-striped">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Quantity</th>
                            <th>Unit Price</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td>@item.Quantity</td>
                                <td>Rs @item.Price.ToString("N2")</td>
                                <td>Rs @((item.Quantity * item.Price).ToString("N2"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
