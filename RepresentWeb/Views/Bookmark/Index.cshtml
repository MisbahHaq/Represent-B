@model representweb.Controllers.BookmarkViewModel
@using representweb.Controllers
@{
    ViewData["Title"] = "Bookmarked Items";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <h2>Bookmarked Items</h2>
            
            @if (Model.Items.Count == 0)
            {
                <div class="alert alert-info">
                    You haven't bookmarked any items yet. <a asp-controller="Products" asp-action="Index">Start browsing</a> to add items to your bookmarks.
                </div>
            }
            else
            {
                <div class="row">
                    @foreach (var item in Model.Items)
                    {
                        <div class="col-md-3 mb-4">
                            <div class="card h-100">
                                @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                                {
                                    <img src="@item.Product.ImageUrl" class="card-img-top" alt="@item.Product.Name" style="height: 200px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                        <span class="text-muted">No Image</span>
                                    </div>
                                }
                                
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title">@item.Product.Name</h5>
                                    <p class="card-text text-muted flex-grow-1">
                                        @item.Product.Description?.Substring(0, Math.Min(100, item.Product.Description?.Length ?? 0))@(item.Product.Description?.Length > 100 ? "..." : "")
                                    </p>
                                    <div class="mt-3">
                                        <h6 class="mb-0">Rs @item.Product.Price.ToString("N2")</h6>
                                    </div>
                                </div>
                                
                                <div class="card-footer bg-white border-top-0 d-flex justify-content-between">
                                    <a asp-controller="Products" asp-action="Details" asp-route-id="@item.Product.Id" class="btn btn-sm btn-outline-primary">View Details</a>
                                    <form asp-controller="Bookmark" asp-action="Remove" method="post" style="display: inline;">
                                        <input type="hidden" name="id" value="@item.Product.Id" />
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-bookmark-slash"></i> Remove
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}