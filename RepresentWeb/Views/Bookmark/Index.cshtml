@model RepresentWeb.Controllers.BookmarkViewModel
@using RepresentWeb.Controllers
@{
    ViewData["Title"] = "Bookmarks";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="section-spacer bg-white">
    <div class="container-fluid" style="max-width: 1300px; padding: 0 clamp(1.5rem, 4vw, 4rem);">

       @if (Model.Items.Count == 0)
{
    <div class="text-center" style="padding: 8rem 0;">
        <p style="font-size: 3rem; margin-bottom: 1rem;">🫥</p>

        <h2 style="font-weight: 500;">Empty.</h2>

        <p style="color: #888; margin: 1rem 0 2rem;">
            Looks like nothing has earned a bookmark yet.
        </p>

        <a asp-controller="Home" asp-action="Index"
           style="color: #1a1a1a; text-decoration: none; border-bottom: 1px solid #1a1a1a;">
            Browse products
        </a>
    </div>
}
        else
        {
            <div class="mb-5 animate-fade-in">
                <p class="text-caption" style="color: #999;">Bookmarks</p>
                <div style="width: 30px; height: 1px; background: #1a1a1a; margin-top: 0.8rem;"></div>
            </div>

            <div class="row gx-4 gy-5">
                @foreach (var item in Model.Items)
                {
                    <div class="col-6 col-md-4 col-lg-3 animate-fade-in">

                        <div class="d-flex flex-column">
                            <a asp-controller="Products" asp-action="Details" asp-route-id="@item.Product.Id"
                               class="d-block text-decoration-none" style="color: inherit;">

                                <div class="img-container aspect-square mb-4" style="background: #f7f7f5;">
                                    @{
                                        var productImage = item.Product.GetImages()?.FirstOrDefault();
                                    }
                                    @if (!string.IsNullOrEmpty(productImage))
                                    {
                                        <img src="@productImage"
                                             alt="@item.Product.Name"
                                             style="object-fit: contain; padding: 1rem;" />
                                    }
                                    else
                                    {
                                        <div class="w-100 h-100 d-flex align-items-center justify-content-center text-muted"
                                             style="font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase;">
                                            No Image
                                        </div>
                                    }
                                </div>

                            </a>

                            <div>
                                <a asp-controller="Products" asp-action="Details" asp-route-id="@item.Product.Id"
                                   class="hover-fade d-block mb-1"
                                   style="font-size: 0.82rem; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none; color: #1a1a1a;">
                                    @item.Product.Name
                                </a>
                                <p class="m-0" style="font-size: 0.78rem; font-weight: 300; color: #888;">
                                    $@item.Product.Price.ToString("N2")
                                </p>
                            </div>

                            <form asp-controller="Bookmark" asp-action="Remove" method="post"
                                  class="mt-3"
                                  style="display: inline;">
                                <input type="hidden" name="id" value="@item.Product.Id" />
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="border-0 bg-transparent p-0"
                                        style="font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase; color: #bbb; cursor: pointer; transition: color 0.4s ease;">
                                    Remove
                                </button>
                            </form>
                        </div>

                    </div>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
