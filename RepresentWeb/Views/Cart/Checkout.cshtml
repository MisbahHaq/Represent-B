@model representweb.Controllers.CartViewModel

@{
    ViewData["Title"] = "Checkout";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h3 class="text-center">Checkout</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Checkout" method="post">
                        <div class="mb-4">
                            <h5>Order Summary</h5>
                            <div class="list-group">
                                @foreach (var item in Model.Items)
                                {
                                    <div class="list-item d-flex justify-content-between align-items-center p-2 border-bottom">
                                        <div>
                                            <h6 class="mb-1">@item.Product.Name</h6>
                                            <p class="mb-0 text-muted">@item.Quantity x @item.Product.Price.ToString("C")</p>
                                        </div>
                                        <span class="fw-bold">@item.Subtotal.ToString("C")</span>
                                    </div>
                                }
                            </div>
                            <div class="d-flex justify-content-between mt-3 pt-2 border-top">
                                <h5>Total:</h5>
                                <h5>@Model.TotalAmount.ToString("C")</h5>
                            </div>
                        </div>

                        <div class="mb-4">
                            <h5>Shipping Address</h5>
                            <p class="text-muted">@Context.Session.GetString("UserAddress")</p>
                            <a asp-action="UpdateAddress" asp-controller="Account" class="btn btn-sm btn-outline-link">Change Address</a>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">Place Order</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h3 class="text-center">Order Summary</h3>
                </div>
                <div class="card-body">
                    <p class="text-center">
                        <i class="bi bi-truck fs-1 text-primary"></i>
                    </p>
                    <p class="text-center">Your order will be shipped to:</p>
                    <p class="text-center fw-bold">@Context.Session.GetString("UserAddress")</p>
                    <hr>
                    <p class="text-center">
                        <small>Estimated delivery: 3-5 business days</small>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>