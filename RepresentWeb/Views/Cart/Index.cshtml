@model RepresentWeb.Controllers.CartController.CartViewModel
@{
    ViewData["Title"] = "Shopping Cart";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="section-spacer bg-white">
    <div class="container-fluid" style="max-width: 1200px; padding: 0 clamp(1.5rem, 4vw, 4rem);">

       @if (Model.Items.Count == 0)
{
    <div class="text-center" style="padding: 8rem 0; max-width: 500px; margin: 0 auto;">
        <div style="font-size: 2.5rem; margin-bottom: 1rem;">🛒</div>

        <h2 style="font-size: 1.5rem; font-weight: 500; margin-bottom: .75rem; color: #1a1a1a;">
            Your cart is empty
        </h2>

        <p style="color: #888; font-size: .95rem; line-height: 1.7; margin-bottom: 2rem;">
            It seems your future purchases haven't arrived yet.
        </p>

        <a asp-controller="Products"
           asp-action="Index"
           style="display: inline-block;
                  text-decoration: none;
                  color: #1a1a1a;
                  border-bottom: 1px solid #1a1a1a;
                  padding-bottom: 2px;
                  font-size: .9rem;
                  letter-spacing: .08em;
                  text-transform: uppercase;">
            Start shopping
        </a>
    </div>
}
        else
        {
            <div class="mb-5 animate-fade-in">
                <p class="text-caption" style="color: #999;">Shopping Cart</p>
                <div style="width: 30px; height: 1px; background: #1a1a1a; margin-top: 0.8rem;"></div>
            </div>

            <div class="row gx-0 gy-4">

                <!-- Cart Items -->
                <div class="col-12 col-lg-8">
                    @foreach (var item in Model.Items)
                    {
                        <div class="animate-fade-in" style="padding: 1.8rem 0; border-bottom: 1px solid #eee;">
                            <div class="row align-items-center g-3">
                                <div class="col-3 col-md-2">
                                    <div class="img-container"
                                         style="aspect-ratio: 3/4; max-height: 140px; background: #f7f7f5;">
                                        @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                                        {
                                            <img src="@item.Product.ImageUrl"
                                                 alt="@item.Product.Name"
                                                 style="object-fit: contain; padding: 0.6rem;" />
                                        }
                                    </div>
                                </div>

                                <div class="col-9 col-md-5">
                                    <a asp-controller="Products" asp-action="Details" asp-route-id="@item.Product.Id"
                                       class="hover-fade"
                                       style="font-size: 0.88rem; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none; color: #1a1a1a;">
                                        @item.Product.Name
                                    </a>
                                    @if (!string.IsNullOrEmpty(item.Product.Description))
                                    {
                                        <p class="m-0 mt-2"
                                           style="font-size: 0.75rem; font-weight: 300; color: #999; line-height: 1.6; max-width: 320px;">
                                            @item.Product.Description.Substring(0, Math.Min(60, item.Product.Description.Length))@(item.Product.Description.Length > 60 ? "..." : "")
                                        </p>
                                    }
                                </div>

                                <div class="col-4 col-md-2">
                                    <p class="m-0"
                                       style="font-size: 0.82rem; font-weight: 300; color: #666;">
                                        Rs @item.Product.Price.ToString("N2")
                                    </p>
                                </div>

                                <div class="col-4 col-md-1">
                                    <span style="font-size: 0.82rem; font-weight: 300; color: #666;">
                                        ×@item.Quantity
                                    </span>
                                </div>

                                <div class="col-4 col-md-2 text-end">
                                    <p class="m-0"
                                       style="font-size: 0.88rem; font-weight: 400; letter-spacing: 0.04em;">
                                        Rs @item.Subtotal.ToString("N2")
                                    </p>
                                </div>
                            </div>

                            <div class="mt-3 text-end">
                                <button class="remove-item border-0 bg-transparent p-0"
                                        data-product-id="@item.Product.Id"
                                        style="font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: #bbb; cursor: pointer; background: none; border: none; transition: color 0.4s ease;">
                                    Remove
                                </button>
                            </div>
                        </div>
                    }

                    <div class="d-flex justify-content-between mt-5 flex-wrap gap-3">
                        <a asp-controller="Products" asp-action="Index"
                           class="btn-minimal text-only">
                            ← Continue Shopping
                        </a>
                    </div>
                </div>

                <!-- Summary -->
                <div class="col-12 col-lg-3 offset-lg-1" style="padding-top: 0.5rem;">

                    <div class="animate-fade-in animate-delay-2">
                        <p class="text-caption mb-4" style="color: #999;">Order Summary</p>

                        <div class="d-flex justify-content-between mb-2" style="font-size: 0.82rem; font-weight: 300;">
                            <span style="color: #666;">Items</span>
                            <span style="color: #1a1a1a;">@Model.Items.Sum(i => i.Quantity)</span>
                        </div>

                        <div class="d-flex justify-content-between mb-2" style="font-size: 0.82rem; font-weight: 300;">
                            <span style="color: #666;">Subtotal</span>
                            <span style="color: #1a1a1a;">Rs @Model.TotalAmount.ToString("N2")</span>
                        </div>

                        <div class="d-flex justify-content-between mb-4" style="font-size: 0.82rem; font-weight: 300;">
                            <span style="color: #666;">Shipping</span>
                            <span style="color: #1a1a1a;">Free</span>
                        </div>

                        <hr class="divider">

                        <div class="d-flex justify-content-between mb-5">
                            <span style="font-size: 0.85rem; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase;">Total</span>
                            <span style="font-size: 0.95rem; font-weight: 300;">Rs @Model.TotalAmount.ToString("N2")</span>
                        </div>

                        <a asp-controller="Cart" asp-action="Checkout"
                           class="btn-minimal btn-filled w-100 text-center"
                           style="display: flex; justify-content: center;">
                            Checkout
                        </a>

                        <div class="mt-3 text-center">
                            <a asp-controller="Account" asp-action="Profile"
                               class="hover-fade"
                               style="font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; color: #999;">
                                View My Account
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.quantity-input').forEach(input => {
                input.addEventListener('change', function () {
                    const productId = parseInt(this.getAttribute('data-product-id'));
                    const quantity = parseInt(this.value);
                    if (quantity < 1) { this.value = 1; return; }
                    fetch('/Cart/Update/' + productId, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': getAntiForgeryToken(),
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: 'id=' + productId + '&quantity=' + quantity
                    })
                    .then(response => response.json())
                    .then(data => { if (data.success) { updateCartCount(); location.reload(); } else { alert('Failed to update cart'); } })
                    .catch(error => { console.error('Error:', error); alert('Network error'); });
                });
            });

            document.querySelectorAll('.remove-item').forEach(button => {
                button.addEventListener('click', function () {
                    if (!confirm('Remove this item from your cart?')) return;
                    const productId = parseInt(this.getAttribute('data-product-id'));
                    fetch('/Cart/Remove/' + productId, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': getAntiForgeryToken(),
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: 'id=' + productId
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            updateCartCount();
                            location.reload();
                        } else { alert('Failed to remove item'); }
                    })
                    .catch(error => { console.error('Error:', error); alert('Network error'); });
                });
            });

            function updateCartCount() {
                fetch('/Cart/GetCount').then(r => r.json()).then(data => {
                    const el = document.querySelector('#cartLink .badge-count');
                    if (el) el.textContent = data.count;
                });
            }
            function getAntiForgeryToken() {
                const t = document.querySelector('[name=__RequestVerificationToken]');
                return t ? t.value : '';
            }
        });
    </script>
}
