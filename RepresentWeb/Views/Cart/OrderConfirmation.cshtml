@model RepresentWeb.Models.Order
@{
    ViewData["Title"] = "Order Confirmed";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="section-spacer bg-white">
    <div class="container-fluid text-center" style="max-width: 680px; padding: 0 clamp(1.5rem, 4vw, 4rem); margin: 0 auto;">

        <div class="text-center animate-fade-in">
            <p class="text-caption animate-fade-in animate-delay-1" style="color: #999;">Order #@Model.Id</p>
            <h1 class="text-heading text-primary animate-fade-in animate-delay-2" style="font-size: 1.6rem; margin-top: 0.8rem;">
                Confirmed
            </h1>
            <div style="width: 30px; height: 1px; background: #1a1a1a; margin: 1.2rem auto 0;"></div>
        </div>

        <div class="animate-fade-in animate-delay-3" style="margin-top: 3rem; font-size: 0.85rem; font-weight: 300; color: #666; line-height: 2;">
            <p>Your order has been placed and is being processed.</p>
            <p style="color: #999;">@Model.OrderDate.ToString("MMMM dd, yyyy — hh:mm tt")</p>
        </div>

        <hr class="divider" style="margin: 3rem 0;">

        <p class="text-caption animate-fade-in animate-delay-3" style="color: #999; margin-bottom: 2rem;">
            Items
        </p>

        <div class="animate-fade-in animate-delay-4">
            @foreach (var item in Model.Items)
            {
                <div style="padding: 1.2rem 0; border-bottom: 1px solid #f0f0ee;">
                    <div class="row align-items-center g-3">
                        <div class="col text-start" style="text-align: left;">
                            <p style="font-size: 0.85rem; font-weight: 400; letter-spacing: 0.05em; text-transform: uppercase;">
                                @item.ProductName
                            </p>
                            <p style="font-size: 0.75rem; font-weight: 300; color: #999;">
                                @item.Quantity × Rs @item.Price.ToString("N2")
                            </p>
                        </div>
                        <div class="col-auto text-end">
                            <p style="font-size: 0.88rem; font-weight: 400;">
                                Rs @((item.Quantity * item.Price).ToString("N2"))
                            </p>
                        </div>
                    </div>
                </div>
            }

            <div class="d-flex justify-content-between mt-4 mb-6">
                <span style="font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase;">Total</span>
                <span style="font-size: 1rem; font-weight: 300;">Rs @Model.TotalAmount.ToString("N2")</span>
            </div>

            <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                <a asp-controller="Home" asp-action="Index" class="btn-minimal">Return Home</a>
                <a asp-controller="Account" asp-action="Profile" class="btn-minimal text-only">View My Orders</a>
            </div>
        </div>

    </div>
</div>
