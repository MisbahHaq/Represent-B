@model representweb.Models.Order

@{
    ViewData["Title"] = "Order Confirmation";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h3 class="text-center">Order Confirmation</h3>
                </div>
                <div class="card-body text-center">
                    <div class="mb-4">
                        <i class="bi bi-check-circle fs-1 text-success"></i>
                    </div>
                    <h4>Thank you for your order!</h4>
                    <p>Your order #@Model.Id has been placed and is being processed.</p>
                    <div class="mb-4">
                        <p><strong>Order Date:</strong> @Model.OrderDate.ToString("MMM dd, yyyy")</p>
                        <p><strong>Status:</strong> <span class="badge bg-info text-dark">@Model.Status</span></p>
                    </div>
                    <h5>Shipping Information</h5>
                    <p>@Model.UserEmail</p>
                    <p>@Context.Session.GetString("UserAddress")</p>
                    <hr>
                    <h5>Order Items</h5>
                    <div class="list-group">
                        @foreach (var item in Model.Items)
                        {
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1">@item.ProductName</h6>
                                    <small>@item.Quantity x @item.Price.ToString("C")</small>
                                </div>
                                <small class="text-muted">@item.Quantity x @item.Price.ToString("C") = @((item.Quantity * item.Price).ToString("C"))</small>
                            </div>
                        }
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <h5>Total:</h5>
                        <h5>@Model.TotalAmount.ToString("C")</h5>
                    </div>
                    <a asp-action="Index" asp-controller="Cart" class="btn btn-outline-primary mt-3">Continue Shopping</a>
                    <a asp-action="Profile" asp-controller="Account" class="btn btn-outline-secondary mt-3">View Orders</a>
                </div>
            </div>
        </div>
    </div>
</div>