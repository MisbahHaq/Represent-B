@{
    ViewData["Title"] = "Home";
    var bestSellers = ViewBag.BestSellers as List<Product> ?? new List<Product>();
}

<style>
    /* --- SYSTEM RESET & HIGH FASHION EDITORIAL BASE --- */
    body {
        background-color: #e5e7eb; 
        color: #000000;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        margin: 0;
        padding: 0;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
    }

    /* --- TOP NAVIGATION BAR --- */
    .velora-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 24px;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        background-color: #e5e7eb;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    }

    .velora-nav a {
        color: #000000;
        text-decoration: none;
        margin-right: 16px;
        font-weight: 500;
    }

    .velora-nav .brand-logo-center {
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        margin: 0;
    }

    .velora-nav .nav-right-side a {
        margin-right: 0;
        margin-left: 16px;
    }

    /* --- ASYMMETRIC HERO CONTAINER --- */
    .hero-split-container {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        min-height: 85vh;
        background-color: #e5e7eb;
    }

    .hero-left-pane {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 40px;
        position: relative;
    }

    .hero-left-pane .main-brand-heading {
        font-size: clamp(4rem, 12vw, 10rem);
        font-weight: 800;
        line-height: 0.85;
        letter-spacing: -0.04em;
        margin: 0;
        text-transform: uppercase;
    }

    .hero-left-pane .hero-product-preview-box {
        width: 100%;
        max-width: 420px;
        margin: auto 0;
        padding: 40px 0;
        display: flex;
        justify-content: center;
    }

    .hero-left-pane .hero-product-preview-box img {
        max-width: 90%;
        height: auto;
        object-fit: contain;
    }

    .hero-left-pane .hero-cta-btn-row {
        width: 100%;
    }

    .btn-velora-dark {
        display: block;
        width: 100%;
        background-color: #1a1c23;
        color: #ffffff;
        text-align: center;
        text-decoration: none;
        text-transform: uppercase;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        padding: 16px;
        transition: background-color 0.2s ease;
    }

    .btn-velora-dark:hover {
        background-color: #000000;
    }

    .hero-right-pane {
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
    }

    .hero-right-pane img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .hero-editorial-statement {
        position: relative;
        z-index: 2;
        color: #ffffff;
        font-size: clamp(1.8rem, 4vw, 3.5rem);
        font-weight: 500;
        line-height: 1.1;
        letter-spacing: -0.02em;
        padding: 40px;
        background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0) 100%);
    }

    /* --- SECONDARY BRAND STATEMENT HEADER --- */
    .secondary-brand-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        padding: 80px 40px 30px 40px;
    }

    .secondary-brand-header h2 {
        font-size: clamp(4rem, 10vw, 8rem);
        font-weight: 800;
        line-height: 0.85;
        letter-spacing: -0.04em;
        margin: 0;
        text-transform: uppercase;
    }

    .secondary-brand-header .header-context-meta {
        display: flex;
        gap: 40px;
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding-bottom: 10px;
    }

    .secondary-brand-header .header-context-meta span {
        opacity: 0.4;
    }

    .secondary-brand-header .header-context-meta a {
        color: #000000;
        text-decoration: none;
    }

    /* --- GRID MATRIX DYNAMIC PRODUCT WRAPPER --- */
    .velora-editorial-matrix {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 60px 24px;
        padding: 0 40px 80px 40px;
    }

    .matrix-item {
        display: flex;
        flex-direction: column;
        text-decoration: none;
        color: inherit;
    }

    .matrix-item-image-wrapper {
        width: 100%;
        aspect-ratio: 3 / 4.2;
        background-color: #f3f4f6; 
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        margin-bottom: 16px;
        border: 1px solid rgba(0,0,0,0.03);
    }

    .matrix-item-image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        padding: 30px;
        transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .matrix-item:hover .matrix-item-image-wrapper img {
        transform: scale(1.04);
    }

    .matrix-text-interstitial {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 30px;
        text-align: center;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        line-height: 1.5;
        border: 1px dashed rgba(0, 0, 0, 0.15);
        aspect-ratio: 3 / 4.2;
        color: #4b5563;
    }

    .product-meta-block {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        font-size: 0.85rem;
        line-height: 1.4;
    }

    .product-info-left .prod-name {
        font-weight: 600;
        color: #000000;
    }

    .product-info-left .prod-price {
        font-size: 0.8rem;
        margin-top: 2px;
        color: #4b5563;
    }

    .product-info-right-swatches {
        display: flex;
        gap: 4px;
        margin-top: 4px;
    }

    .swatch-dot {
        width: 8px;
        height: 8px;
        background-color: #000;
        display: inline-block;
    }

    /* --- SPLIT BANNER NAVIGATION SECTION --- */
    .gender-split-banner {
        display: grid;
        grid-template-columns: 1fr 1fr;
        height: 50vh;
        gap: 2px;
        background-color: #e5e7eb;
    }

    .gender-panel {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        overflow: hidden;
    }

    .gender-panel img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: brightness(0.85);
        transition: transform 0.6s ease;
    }

    .gender-panel:hover img {
        transform: scale(1.03);
    }

    .gender-panel span {
        position: relative;
        z-index: 2;
        color: #ffffff;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        border-bottom: 1px solid #ffffff;
        padding-bottom: 4px;
    }

    /* --- EDITORIAL MANIFESTO SECTION --- */
    .manifesto-section {
        padding: 100px 40px;
        max-width: 900px;
    }

    .manifesto-section p.brand-about-tag {
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 16px;
        opacity: 0.5;
    }

    .manifesto-section h3 {
        font-size: clamp(1.8rem, 4vw, 3.2rem);
        font-weight: 600;
        line-height: 1.15;
        letter-spacing: -0.02em;
        margin: 0 0 40px 0;
        color: #111111;
    }

    .manifesto-subtext-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
        font-size: 0.85rem;
        line-height: 1.6;
        color: #374151;
    }

    /* --- NEWSLETTER SUBSCRIPTION COMPONENT --- */
    .newsletter-row-banner {
        background-color: #1a1c23;
        color: #ffffff;
        padding: 80px 40px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .newsletter-row-banner h4 {
        font-size: clamp(2rem, 5vw, 4rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin: 0 0 24px 0;
        text-transform: uppercase;
    }

    .newsletter-form-box {
        display: flex;
        width: 100%;
        max-width: 500px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.3);
        padding-bottom: 8px;
    }

    .newsletter-form-box input[type="email"] {
        flex: 1;
        background: transparent;
        border: none;
        color: #ffffff;
        font-size: 0.9rem;
        padding: 8px 0;
    }

    .newsletter-form-box input[type="email"]:focus {
        outline: none;
    }

    .newsletter-form-box button {
        background: transparent;
        border: none;
        color: #ffffff;
        cursor: pointer;
        padding: 0 8px;
    }

    /* --- MINIMALIST FOOTER BRICK --- */
    .editorial-footer-container {
        padding: 80px 40px 30px 40px;
        background-color: #e5e7eb;
    }

    .footer-giant-text {
        font-size: clamp(3rem, 9vw, 8rem);
        font-weight: 800;
        line-height: 0.85;
        letter-spacing: -0.04em;
        text-transform: uppercase;
        margin-bottom: 60px;
    }

    .footer-links-matrix {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        font-size: 0.8rem;
    }

    .footer-links-matrix .footer-column {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .footer-links-matrix .footer-column a {
        color: #000000;
        text-decoration: none;
        font-weight: 500;
    }

    .footer-links-matrix .social-column {
        text-align: right;
    }

    .copyright-bar {
        margin-top: 60px;
        border-top: 1px solid rgba(0,0,0,0.06);
        padding-top: 20px;
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        opacity: 0.5;
        text-align: center;
    }

    /* --- RESPONSIVE BREAKPOINTS --- */
    @@media (max-width: 991.98px) {
        .hero-split-container {
            grid-template-columns: 1fr;
        }
        .hero-right-pane {
            min-height: 50vh;
        }
        .velora-editorial-matrix {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
        .secondary-brand-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 16px;
        }
        .manifesto-subtext-grid {
            grid-template-columns: 1fr;
            gap: 20px;
        }
    }

    @@media (max-width: 575.98px) {
        .velora-editorial-matrix {
            grid-template-columns: 1fr;
            padding: 0 20px 60px 20px;
        }
        .gender-split-banner {
            grid-template-columns: 1fr;
            height: 70vh;
        }
        .footer-links-matrix {
            flex-direction: column;
            align-items: flex-start;
            gap: 30px;
        }
        .footer-links-matrix .social-column {
            text-align: left;
        }
    }
</style>

