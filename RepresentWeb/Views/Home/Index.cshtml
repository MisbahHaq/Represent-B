@{
    ViewData["Title"] = "Home";
}

<!-- FIRST HERO -->
<section class="relative w-full" style="height: 100svh; overflow: hidden;">
    <img src="/assets/first-pic.png"
         alt="Campaign"
         class="absolute inset-0 w-full h-full object-cover"
         style="transition: transform 1.2s cubic-bezier(0.25, 0.1, 0.25, 1);" />

    <div class="absolute inset-0"
         style="background: linear-gradient(to top, rgba(0,0,0,0.25) 0%, transparent 40%);"></div>

    <div class="absolute inset-0 flex flex-col items-center justify-end"
         style="padding-bottom: clamp(5rem, 10vh, 9rem);">

        <div class="text-center animate-fade-in" style="color: #fff;">
            <p class="text-subheading animate-fade-in animate-delay-1 mb-3"
               style="color: #fff; opacity: 0.85;">
                Now Live
            </p>

            <h1 class="text-display animate-fade-in animate-delay-2 mb-6"
                style="color: #fff; font-weight: 250;">
                High Summer
            </h1>

            <a href="/Home/Men"
               class="btn-minimal animate-fade-in animate-delay-3"
               style="border-color: rgba(255,255,255,0.7); color: #fff;">
                Shop Now
            </a>
        </div>

    </div>
</section>

<!-- SECOND HERO -->
<section class="relative w-full" style="height: 100svh; overflow: hidden;">
    <img src="/assets/second-pic-main.png"
         alt="Campaign"
         class="absolute inset-0 w-full h-full object-cover"
         style="transition: transform 1.2s cubic-bezier(0.25, 0.1, 0.25, 1);" />

    <div class="absolute inset-0"
         style="background: linear-gradient(to top, rgba(0,0,0,0.3) 0%, transparent 50%);"></div>

    <div class="absolute inset-0 flex flex-col items-center justify-end"
         style="padding-bottom: clamp(5rem, 10vh, 9rem);">

        <div class="text-center animate-fade-in" style="color: #fff; max-width: 900px; padding: 0 1.5rem;">
            <p class="text-subheading animate-fade-in animate-delay-1 mb-3"
               style="color: #fff; opacity: 0.8;">
                New Release
            </p>

            <h2 class="animate-fade-in animate-delay-2 mb-4"
                style="font-size: clamp(2rem, 5vw, 4.5rem); font-weight: 200; letter-spacing: 0.06em; text-transform: uppercase; line-height: 1.1; color: #fff;">
                247 Rivington<br>Capsule
            </h2>

            <p class="animate-fade-in animate-delay-3"
               style="font-size: 0.8rem; font-weight: 300; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.75);">
                On a mission.
            </p>
        </div>

    </div>
</section>

<!-- EDITORIAL VIDEO SECTION -->
<section class="relative w-full" style="height: 100svh; overflow: hidden;">
    <video autoplay loop muted playsinline
           class="absolute inset-0 w-full h-full object-cover"
           style="min-width: 100%; min-height: 100%;">
        <source src="/assets/third-video-main.webm" type="video/webm">
    </video>
</section>

<!-- LOOKBOOK / FOURTH VIDEO -->
<section class="relative w-full" style="height: 100svh; overflow: hidden;">
    <video autoplay loop muted playsinline
           class="absolute inset-0 w-full h-full object-cover"
           style="min-width: 100%; min-height: 100%;">
        <source src="/assets/fourth-video-main.webm" type="video/webm">
    </video>
</section>



