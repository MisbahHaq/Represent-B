@{
    ViewData["Title"] = "Home Page";
}

<style>
    body {
        margin: 0;
    }

    .hero {
        height: 100vh;
        overflow: hidden;
    }

    .hero img {
        object-fit: cover;
    }

    .hero-overlay {
        bottom: 60px;
    }
</style>

<div class="container-fluid p-0">

    <div class="hero position-relative w-100">

        <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQ8qcK5S6qFAYjn9b4Da0z8jBcXNRKHMirKIg&s"
             class="position-absolute top-0 start-0 w-100 h-100" />

        <div class="hero-overlay position-absolute start-50 translate-middle-x text-center text-white">

            <p class="mb-2">NOW LIVE!</p>

            <h2 class="fw-bold mb-4">HIGH SUMMER</h2>

            <div class="d-flex gap-3 justify-content-center">
                <button class="btn btn-light px-4">
                    SHOP NOW
                </button>

                <button class="btn btn-outline-light px-4">
                    VIEW LOOKBOOK
                </button>
            </div>

        </div>

    </div>

    <div class="hero position-relative w-100">

        <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQ8qcK5S6qFAYjn9b4Da0z8jBcXNRKHMirKIg&s"
             class="position-absolute top-0 start-0 w-100 h-100" />

        <div class="hero-overlay position-absolute start-50 translate-middle-x text-center text-white">

            <p class="mb-2">NOW LIVE!</p>

            <h2 class="fw-bold mb-4">247 RIVINGTON CAPSULE</h2>

            <p class="mb-2">ON A MISSION.</p>

            <div class="d-flex gap-3 justify-content-center">
                <button class="btn btn-light px-4">
                    SHOP NOW
                </button>
            </div>

        </div>

    </div>

</div>