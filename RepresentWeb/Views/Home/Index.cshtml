@{
    ViewData["Title"] = "Home";
    var bestSellers = ViewBag.BestSellers as List<Product> ?? new List<Product>();
}

<style>
    .home-page {
        --ink: #111111;
        --muted: #6b6258;
        --line: rgba(17, 17, 17, 0.12);
        --paper: #f7f4ee;
        --paper-2: #ffffff;
        --charcoal: #161616;
        background: var(--paper);
        color: var(--ink);
        overflow-x: hidden;
    }

    .home-page a {
        color: inherit;
        text-decoration: none;
    }

    .home-page img {
        max-width: 100%;
    }

    .home-hero {
        min-height: 82vh;
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(420px, 0.95fr);
        gap: clamp(1.25rem, 3vw, 3rem);
        align-items: stretch;
        padding: clamp(1rem, 3vw, 2rem);
    }

    .home-hero-copy {
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: clamp(1.5rem, 4vw, 4rem);
    }

    .home-kicker,
    .section-kicker {
        margin: 0 0 1rem;
        color: var(--muted);
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.22em;
        text-transform: uppercase;
    }

    .home-hero-title {
        max-width: 760px;
        margin: 0;
        font-size: clamp(3.25rem, 9vw, 8.5rem);
        font-weight: 800;
        line-height: 0.86;
        letter-spacing: -0.075em;
        text-transform: uppercase;
    }

    .home-hero-lede {
        max-width: 560px;
        margin: 1.5rem 0 0;
        color: #3f3932;
        font-size: clamp(1rem, 1.4vw, 1.2rem);
        line-height: 1.7;
    }

    .home-hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 2rem;
    }

    .home-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 1.35rem;
        border: 1px solid var(--ink);
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        transition: transform 0.2s ease, background-color 0.2s ease, color 0.2s ease;
    }

    .home-btn:hover {
        transform: translateY(-2px);
    }

    .home-btn-dark {
        background: var(--charcoal);
        color: #ffffff;
    }

    .home-btn-light {
        background: transparent;
        color: var(--ink);
    }

    .home-hero-visual-grid {
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        grid-template-rows: repeat(2, minmax(210px, 1fr));
        gap: 1rem;
        min-height: 620px;
        padding: clamp(1.5rem, 4vw, 4rem) clamp(1.5rem, 4vw, 4rem) clamp(1.5rem, 4vw, 4rem) 0;
    }

    .hero-visual-card {
        position: relative;
        overflow: hidden;
        background: #ebe6dc;
        border: 1px solid var(--line);
    }

    .hero-visual-card-large {
        grid-row: 1 / span 2;
    }

    .hero-visual-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .hero-visual-card:hover img {
        transform: scale(1.04);
    }

    .hero-visual-note {
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 1.25rem;
        background: #171717;
        color: #ffffff;
    }

    .hero-visual-note strong {
        font-size: clamp(1.25rem, 2vw, 2rem);
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 1;
        text-transform: uppercase;
    }

    .hero-visual-note span {
        margin-top: 0.5rem;
        color: rgba(255, 255, 255, 0.72);
        font-size: 0.78rem;
        line-height: 1.5;
    }

    .home-section {
        padding: clamp(3.5rem, 8vw, 7rem) clamp(1rem, 3vw, 2rem);
    }

    .home-section-white {
        background: var(--paper-2);
    }

    .section-shell {
        max-width: 1560px;
        margin: 0 auto;
    }

    .section-heading {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 2rem;
        margin-bottom: clamp(1.5rem, 4vw, 3rem);
    }

    .section-heading h2 {
        margin: 0;
        font-size: clamp(2.4rem, 7vw, 6.5rem);
        font-weight: 800;
        line-height: 0.88;
        letter-spacing: -0.065em;
        text-transform: uppercase;
    }

    .section-heading p {
        max-width: 460px;
        margin: 0;
        color: var(--muted);
        font-size: 0.92rem;
        line-height: 1.7;
    }

    .product-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: clamp(0.9rem, 1.5vw, 1.35rem);
    }

    .product-card {
        display: flex;
        flex-direction: column;
        min-width: 0;
        background: transparent;
    }

    .product-card-media {
        position: relative;
        overflow: hidden;
        aspect-ratio: 3 / 4;
        background: #eee9df;
        border: 1px solid var(--line);
        margin-bottom: 0.9rem;
    }

    .product-card-media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .product-card:hover .product-card-media img {
        transform: scale(1.045);
    }

    .product-card-meta {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 0.75rem;
    }

    .product-card-meta h3 {
        margin: 0;
        color: var(--ink);
        font-size: 0.88rem;
        font-weight: 700;
        line-height: 1.35;
        letter-spacing: 0.02em;
        text-transform: uppercase;
    }

    .product-card-meta p {
        margin: 0.25rem 0 0;
        color: var(--muted);
        font-size: 0.82rem;
    }

    .product-card-link {
        flex: 0 0 auto;
        color: var(--muted);
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

    .category-grid {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        grid-template-rows: 280px 340px;
        gap: clamp(0.9rem, 1.5vw, 1.35rem);
    }

    .category-card {
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: flex-end;
        padding: 1.5rem;
        background: #e7e0d5;
        border: 1px solid var(--line);
    }

    .category-card-wide {
        grid-row: 1 / span 2;
    }

    .category-card img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: brightness(0.88);
        transition: transform 0.65s cubic-bezier(0.16, 1, 0.3, 1), filter 0.3s ease;
    }

    .category-card:hover img {
        transform: scale(1.045);
        filter: brightness(0.78);
    }

    .category-card-content {
        position: relative;
        z-index: 1;
        color: #ffffff;
    }

    .category-card-content span {
        display: block;
        margin-bottom: 0.5rem;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
    }

    .category-card-content strong {
        font-size: clamp(2rem, 4vw, 4.4rem);
        font-weight: 800;
        line-height: 0.9;
        letter-spacing: -0.06em;
        text-transform: uppercase;
    }

    .feature-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1px;
        background: var(--line);
        border: 1px solid var(--line);
    }

    .feature-tile {
        min-height: 260px;
        padding: clamp(1.5rem, 3vw, 2.5rem);
        background: var(--paper);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 2rem;
    }

    .feature-tile span {
        color: var(--muted);
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
    }

    .feature-tile strong {
        display: block;
        max-width: 380px;
        font-size: clamp(1.6rem, 3vw, 3rem);
        font-weight: 800;
        line-height: 0.95;
        letter-spacing: -0.055em;
        text-transform: uppercase;
    }

    .feature-tile p {
        max-width: 320px;
        margin: 0;
        color: var(--muted);
        font-size: 0.9rem;
        line-height: 1.7;
    }

    .newsletter-panel {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 2rem;
        align-items: center;
        padding: clamp(2rem, 5vw, 4rem);
        background: #161616;
        color: #ffffff;
    }

    .newsletter-panel h2 {
        margin: 0;
        font-size: clamp(2.4rem, 6vw, 6rem);
        font-weight: 800;
        line-height: 0.9;
        letter-spacing: -0.065em;
        text-transform: uppercase;
    }

    .newsletter-panel p {
        max-width: 520px;
        margin: 1rem 0 0;
        color: rgba(255, 255, 255, 0.72);
        line-height: 1.7;
    }

    .newsletter-form {
        width: min(460px, 100%);
        display: flex;
        border-bottom: 1px solid rgba(255, 255, 255, 0.35);
    }

    .newsletter-form input {
        min-width: 0;
        flex: 1;
        border: 0;
        background: transparent;
        color: #ffffff;
        padding: 0.85rem 0;
        font-size: 0.95rem;
    }

    .newsletter-form input::placeholder {
        color: rgba(255, 255, 255, 0.55);
    }

    .newsletter-form input:focus {
        outline: none;
    }

    .newsletter-form button {
        border: 0;
        background: transparent;
        color: #ffffff;
        cursor: pointer;
        padding: 0.85rem 0;
    }

    @@media (max-width: 1180px) {
        .home-hero {
            grid-template-columns: 1fr;
        }

        .home-hero-visual-grid {
            padding: 0;
            min-height: auto;
        }

        .hero-visual-card-large {
            min-height: 520px;
        }

        .product-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @@media (max-width: 860px) {
        .home-hero-copy {
            padding: 2rem 0;
        }

        .home-hero-visual-grid {
            grid-template-columns: 1fr;
            grid-template-rows: auto;
        }

        .hero-visual-card-large,
        .hero-visual-card {
            min-height: 360px;
        }

        .section-heading,
        .newsletter-panel {
            grid-template-columns: 1fr;
            flex-direction: column;
            align-items: flex-start;
        }

        .product-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .category-grid {
            grid-template-columns: 1fr;
            grid-template-rows: 360px 300px 280px;
        }

        .category-card-wide {
            grid-row: auto;
        }

        .feature-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 575.98px) {
        .home-hero {
            padding: 0.5rem;
        }

        .home-hero-title {
            font-size: clamp(3rem, 18vw, 5.2rem);
        }

        .product-grid {
            grid-template-columns: 1fr;
        }

        .hero-visual-card-large,
        .hero-visual-card {
            min-height: 300px;
        }

        .category-grid {
            grid-template-rows: 320px 260px 240px;
        }

        .feature-tile {
            min-height: 220px;
        }
    }
</style>

<div class="home-page">
    <section class="home-hero">
        <div class="home-hero-copy">
            <p class="home-kicker">Represent / New Season</p>
            <h1 class="home-hero-title">Quiet luxury with a sharper edge</h1>
            <p class="home-hero-lede">A refined edit of menswear, womenswear and statement pieces built around clean silhouettes, premium textures and everyday confidence.</p>
            <div class="home-hero-actions">
                <a class="home-btn home-btn-dark" href="/Home/Men">Shop Men</a>
                <a class="home-btn home-btn-light" href="/Home/Women">Shop Women</a>
                <a class="home-btn home-btn-light" href="#bestsellers">View Bestsellers</a>
            </div>
        </div>

        <div class="home-hero-visual-grid">
            <div class="hero-visual-card hero-visual-card-large">
                <img src="@Url.Content("~/assets/second-pic-main.png")" alt="Represent editorial fashion look" loading="eager" />
            </div>
            <div class="hero-visual-card">
                <img src="@Url.Content("~/assets/man.png")" alt="Represent men collection" loading="lazy" />
            </div>
            <div class="hero-visual-card hero-visual-note">
                <strong>New drops weekly</strong>
                <span>Fresh pieces added to the collection as soon as they land.</span>
            </div>
        </div>
    </section>

    <section class="home-section home-section-white" id="bestsellers">
        <div class="section-shell">
            <div class="section-heading">
                <div>
                    <p class="section-kicker">Bestsellers</p>
                    <h2>Current favorites</h2>
                </div>
                <p>Explore the latest pieces selected for strong styling, clean proportions and everyday wearability.</p>
            </div>

            @if (bestSellers.Any())
            {
                <div class="product-grid">
                    @foreach (var product in bestSellers.Take(8))
                    {
                        var productImage = product.GetImages()?.FirstOrDefault() ?? Url.Content("~/assets/acc.webp");

                        <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="product-card">
                            <div class="product-card-media">
                                <img src="@productImage" alt="@product.Name" loading="lazy" decoding="async" />
                            </div>
                            <div class="product-card-meta">
                                <div>
                                    <h3>@product.Name</h3>
                                    <p>Rs @product.Price.ToString("N0")</p>
                                </div>
                                <span class="product-card-link">View</span>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="feature-grid">
                    <div class="feature-tile">
                        <span>Collection</span>
                        <strong>No products yet</strong>
                        <p>Add products from the admin panel and they will appear here in the homepage grid.</p>
                    </div>
                </div>
            }
        </div>
    </section>

    <section class="home-section">
        <div class="section-shell">
            <div class="section-heading">
                <div>
                    <p class="section-kicker">Shop by edit</p>
                    <h2>Choose your lane</h2>
                </div>
                <p>Designed as a cleaner shopping path, each category opens into a focused grid for faster browsing.</p>
            </div>

            <div class="category-grid">
                <a href="/Home/Men" class="category-card category-card-wide">
                    <img src="@Url.Content("~/assets/first-pic.png")" alt="Shop men collection" loading="lazy" />
                    <div class="category-card-content">
                        <span>Men</span>
                        <strong>Sharp essentials</strong>
                    </div>
                </a>
                <a href="/Home/Women" class="category-card">
                    <img src="@Url.Content("~/assets/woman.jpg")" alt="Shop women collection" loading="lazy" />
                    <div class="category-card-content">
                        <span>Women</span>
                        <strong>Modern forms</strong>
                    </div>
                </a>
                <a href="/Home/Vault" class="category-card">
                    <img src="@Url.Content("~/assets/vault.png")" alt="Shop The Vault collection" loading="lazy" />
                    <div class="category-card-content">
                        <span>The Vault</span>
                        <strong>Rare pieces</strong>
                    </div>
                </a>
            </div>
        </div>
    </section>

    <section class="home-section">
        <div class="section-shell">
            <div class="feature-grid">
                <div class="feature-tile">
                    <span>Build</span>
                    <strong>Clean structure</strong>
                    <p>Every layout uses consistent spacing, strong image hierarchy and responsive grid columns.</p>
                </div>
                <div class="feature-tile">
                    <span>Texture</span>
                    <strong>Premium finish</strong>
                    <p>Large visuals, restrained typography and neutral backgrounds keep the focus on the product.</p>
                </div>
                <div class="feature-tile">
                    <span>Motion</span>
                    <strong>Subtle depth</strong>
                    <p>Hover states and scaled imagery add polish without slowing down the browsing experience.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="home-section home-section-white">
        <div class="section-shell">
            <div class="newsletter-panel">
                <div>
                    <p class="section-kicker">Inner circle</p>
                    <h2>Get the next drop first</h2>
                    <p>Join the list for new releases, restocks and member-only access to the latest edits.</p>
                </div>
                <form action="#" method="post" class="newsletter-form">
                    <input type="email" placeholder="Email address" aria-label="Email subscription entry field" required />
                    <button type="submit" aria-label="Submit subscription">Join</button>
                </form>
            </div>
        </div>
    </section>
</div>
