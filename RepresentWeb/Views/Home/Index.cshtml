<section class="secondary-brand-header" id="shop-collection">
    <h2>VELORA</h2>
    <div class="header-context-meta">
        <span>Bestsellers</span>
    </div>
</section>

<section>
    <div class="velora-editorial-matrix">
        @{
            int index = 0;
            foreach (var product in bestSellers.Take(6))
            {
                index++;
                var productImage = product.GetImages()?.FirstOrDefault() ?? "/assets/placeholder.jpg";

                <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="matrix-item">
                    <div class="matrix-item-image-wrapper">
                        <img src="@productImage" alt="@product.Name" loading="lazy" />
                    </div>
                    <div class="product-meta-block">
                        <div class="product-info-left">
                            <div class="prod-name">@product.Name</div>
                            <div class="prod-price">Rs @product.Price.ToString("N0")</div>
                        </div>
                        <div class="product-info-right-swatches">
                            <span class="swatch-dot" style="background-color: #000000;"></span>
                            @if(index % 2 == 0) {
                                <span class="swatch-dot" style="background-color: #4b5563;"></span>
                            }
                        </div>
                    </div>
                </a>

                if (index == 2)
                {
                    <div class="matrix-text-interstitial d-none d-md-flex">
                        <span>Confidence begins with what you wear</span>
                    </div>
                }
                if (index == 4)
                {
                    <div class="matrix-text-interstitial d-none d-md-flex">
                        <span>Timeless form modern attitude</span>
                    </div>
                }
            }
        }
    </div>
</section>

<section class="gender-split-banner">
    <a href="/Home/Men" class="gender-panel">
        <img src="/assets/first-pic.png" alt="Shop Men" />
        <span>Male</span>
    </a>
    <a href="/Home/women" class="gender-panel">
        <img src="/assets/woman.png" alt="Shop Women" />
        <span>Female</span>
    </a>
</section>

<section class="manifesto-section">
    <p class="brand-about-tag">About us</p>
    <h3>Velora — for those who value quiet confidence and uncompromising quality. We believe true luxury lies in precision and intention.</h3>
    
    <div class="manifesto-subtext-grid">
        <div>
            We select only premium fabrics sourced from trusted European mills. Our collections combine timeless silhouettes with contemporary structures.
        </div>
        <div>
            Every detail is designed intentionally to provide a functional architectural wardrobe that outlasts fleeting stylistic seasonal trends.
        </div>
    </div>
</section>

<section class="newsletter-row-banner">
    <h4>Join the Inner Circle</h4>
    <form action="#" method="post" class="newsletter-form-box">
        <input type="email" placeholder="Email" required aria-label="Email subscription entry field"/>
        <button type="submit" aria-label="Submit subscription">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
    </form>
</section>

