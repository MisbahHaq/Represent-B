@model IEnumerable<representweb.Models.Product>

@{
    ViewData["Title"] = "Men";
}

<div class="section-spacer bg-white">
    <div class="container-fluid" style="max-width: 1500px; padding: 0 clamp(1.5rem, 5vw, 5rem);">

        <div class="mb-5 animate-fade-in">
            <h1 class="text-heading text-primary m-0">Men</h1>
            <div style="width: 40px; height: 1px; background: #1a1a1a; margin-top: 1.2rem;"></div>
        </div>

        <div class="row gx-4 gy-5">
            @foreach (var item in Model)
            {
                <div class="col-6 col-md-4 col-lg-3 animate-fade-in">

                    <a asp-controller="Products" asp-action="Details" asp-route-id="@item.Id"
                       class="d-block text-decoration-none" style="color: inherit;">

                        <div class="img-container aspect-portrait mb-4"
                             style="background: #f5f5f3;">

                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl"
                                     alt="@item.Name"
                                     style="object-fit: contain; padding: 1.2rem;" />
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex align-items-center justify-content-center text-muted"
                                     style="font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase;">
                                    No Image
                                </div>
                            }

                        </div>

                        <div class="px-1">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h3 class="m-0"
                                    style="font-size: 0.85rem; font-weight: 400; letter-spacing: 0.08em; text-transform: uppercase; line-height: 1.3;">
                                    @item.Name
                                </h3>
                            </div>

                            <p class="m-0"
                               style="font-size: 0.78rem; font-weight: 300; color: #888;">
                                Rs. @item.Price.ToString("N2")
                            </p>
                        </div>

                    </a>

                </div>
            }
        </div>

    </div>
</div>