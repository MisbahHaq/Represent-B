@model IEnumerable<representweb.Models.Product>

@{
    ViewData["Title"] = "Men";
}

<div class="py-5 bg-white">
    <div class="container-fluid px-4 px-md-5" style="max-width: 1600px;">

        <header class="mb-5 pb-2">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h1 class="fs-4 fw-light text-uppercase tracking-widest m-0 text-dark">Men</h1>
                    <span class="text-muted small fw-light">@Model.Count() Styles</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <label class="text-uppercase tracking-widest small-caption text-muted mb-0">Sort by:</label>
                    <select id="sortFilter" class="form-select form-select-sm" style="width: auto;" 
                        data-current-sort="@ViewBag.CurrentSort">
                        <option value="newest">Newest</option>
                        <option value="price-low-high">Price: Low to High</option>
                        <option value="price-high-low">Price: High to Low</option>
                        <option value="name-a-z">Name: A-Z</option>
                        <option value="name-z-a">Name: Z-A</option>
                    </select>
                </div>
            </div>
        </header>
        
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const sortFilter = document.getElementById('sortFilter');
                const currentSort = sortFilter.dataset.currentSort;
                if (currentSort) {
                    sortFilter.value = currentSort;
                }
                sortFilter.addEventListener('change', function() {
                    const sortValue = this.value;
                    const url = new URL(window.location.href);
                    url.searchParams.set('sort', sortValue);
                    window.location.href = url.toString();
                });
            });
        </script>

        <div class="row g-4 row-cols-2 row-cols-md-3 row-cols-lg-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <a asp-controller="Products" asp-action="Details" asp-route-id="@item.Id"
                       class="d-block text-decoration-none group-hover text-dark">

                        <div class="position-relative overflow-hidden mb-3 bg-neutral-light aspect-ratio-portrait">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl"
                                     alt="@item.Name"
                                     class="w-100 h-100 product-img" />
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex align-items-center justify-content-center text-muted text-uppercase tracking-wider small-caption">
                                    No Image
                                </div>
                            }
                        </div>

                        <div class="d-flex justify-content-between align-items-baseline pt-1">
                            <h3 class="m-0 text-uppercase tracking-wide product-title fs-6">
                                @item.Name
                            </h3>
                            <span class="product-price">
                                Rs. @item.Price.ToString("N0")
                            </span>
                        </div>

                    </a>
                </div>
            }
        </div>

    </div>
</div>