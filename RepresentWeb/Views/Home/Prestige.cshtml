@{
    ViewData["Title"] = "Prestige";
}

<div class="relative w-full" style="height: 100svh; overflow: hidden;">
    <img src="https://representclothes.vercel.app/assets/prestige.avif"
         alt="Prestige Membership"
         class="absolute inset-0 w-full h-full object-cover" />

    <div class="absolute inset-0"
         style="background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 55%);"></div>

    <div class="absolute inset-0 flex flex-col items-center justify-end"
         style="padding-bottom: clamp(5rem, 9vh, 8rem);">
        <div class="text-center animate-fade-in" style="color: #fff; max-width: 680px; padding: 0 1.5rem;">
            <p class="text-subheading animate-fade-in animate-delay-1 mb-3"
               style="color: rgba(255,255,255,0.7); letter-spacing: 0.28em;">
                Exclusive
            </p>
            <h1 class="animate-fade-in animate-delay-2"
                style="font-size: clamp(1.8rem, 4vw, 3.2rem); font-weight: 250; letter-spacing: 0.12em; text-transform: uppercase; line-height: 1.15; color: #fff; margin-bottom: 0.4rem;">
                Prestige<br>Membership
            </h1>
            <p class="animate-fade-in animate-delay-3"
               style="font-size: 0.75rem; font-weight: 300; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-bottom: 2.5rem;">
                10% off your first order
            </p>
            <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center animate-fade-in animate-delay-4">
                <a asp-controller="Home" asp-action="Men" class="btn-minimal"
                   style="border-color: rgba(255,255,255,0.8); color: #fff;">
                    Shop Now
                </a>
                <a asp-controller="Home" asp-action="Index" class="btn-minimal text-only"
                   style="border-color: rgba(255,255,255,0.4); color: rgba(255,255,255,0.9);">
                    View Lookbook
                </a>
            </div>
        </div>
    </div>
</div>
