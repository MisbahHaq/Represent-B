@model IEnumerable<RepresentWeb.Models.Product>
@{
    ViewData["Title"] = $"Search: {(ViewData["SearchQuery"] as string) ?? ""}";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="section-spacer bg-white">
    <div class="container-fluid px-4 px-lg-5" style="max-width: 1400px;">

        <div class="text-center mb-5">
            <h1 class="text-heading text-primary m-0" style="font-size: 1.4rem;">
                Search Results
            </h1>
            @if (ViewData["SearchQuery"] != null)
            {
                <p class="text-caption mt-2" style="color: #999;">
                    For "@ViewData["SearchQuery"]"
                </p>
            }
            <div style="width: 40px; height: 1px; background: #1a1a1a; margin: 1.2rem auto 0;"></div>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <p class="text-caption" style="color: #999;">No products found.</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var product in Model)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" 
                           class="d-block text-decoration-none">
                            <div style="aspect-ratio: 1/1; overflow: hidden; margin-bottom: 0.8rem;">
                                @{
                                    var productImage = product.GetImages()?.FirstOrDefault();
                                }
                                @if (!string.IsNullOrEmpty(productImage))
                                {
                                    <img src="@productImage" alt="@product.Name" 
                                         class="w-100 h-100 object-cover" />
                                }
                                else
                                {
                                    <div class="w-100 h-100 bg-light d-flex align-items-center justify-content-center">
                                        <span class="text-caption" style="color: #999;">No Image</span>
                                    </div>
                                }
                            </div>
                            <h3 class="text-caption m-0" style="color: #1a1a1a; font-weight: 300;">@product.Name</h3>
                            <p class="text-caption m-0 mt-1" style="color: #666;">$@product.Price.ToString("N2")</p>
                        </a>
                    </div>
                }
            </div>
        }

    </div>
</div>