@{
    ViewData["Title"] = "The Vault";
}

<div class="relative w-full" style="height: 100svh; overflow: hidden; background: #0a0a0a;">
    <img src="https://representclothes.vercel.app/assets/vault.png"
         alt="The Vault"
         class="absolute inset-0 w-full h-full object-cover opacity-20" />

    <div class="absolute inset-0 flex flex-col items-center justify-center text-center"
         style="padding: 0 1.5rem;">
        <p class="text-caption animate-fade-in mb-4" style="color: #555; letter-spacing: 0.25em;">
            Members Only
        </p>
        <h1 class="animate-fade-in animate-delay-1"
            style="font-size: clamp(1.6rem, 3.5vw, 3rem); font-weight: 200; letter-spacing: 0.1em; text-transform: uppercase; color: #fff; line-height: 1.2;">
            The Vault<br>Is Closed
        </h1>
        <div style="width: 24px; height: 1px; background: #333; margin: 2rem 0;"></div>
        <a asp-controller="Home" asp-action="Index"
           class="btn-minimal animate-fade-in animate-delay-2"
           style="border-color: #444; color: #888; letter-spacing: 0.2em;">
            Back to Home
        </a>
    </div>
</div>
