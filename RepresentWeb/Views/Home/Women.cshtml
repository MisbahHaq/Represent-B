@model IEnumerable<representweb.Models.Product>

@{
    ViewData["Title"] = "Women";
}

<div class="container-fluid px-4 py-5 bg-white" style="font-family: sans-serif; letter-spacing: 0.5px;">
    
    <div class="text-center mb-5">
        <span class="text-muted text-uppercase small tracking-widest" style="letter-spacing: 3px;">REPRESENT</span>
    </div>

    <div class="mb-5">
        <h2 class="fw-bold text-uppercase m-0" style="font-size: 1.5rem; letter-spacing: 1px;">WOMEN'S NEW ARRIVALS</h2>
        <p class="text-muted mt-2 mb-0" style="font-size: 0.85rem; max-width: 600px; line-height: 1.5;">
            Discover the latest arrivals from Represent. Some of the latest additions to our new arrivals collection include 247 (Architect), our SS26 'Overdrive' Collection, and collaboration with Oasis. Buy now, pay later available with Klarna.
        </p>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-12 col-md-4">
                <div class="position-relative d-flex flex-column h-100 border-0" style="background-color: #f8f8f8;">
                    
                    <div class="p-5 d-flex align-items-center justify-content-center" style="min-height: 400px;">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="@item.Name" class="img-fluid" style="max-height: 300px; object-fit: contain;" />
                        }
                        else
                        {
                            <div class="text-muted small">No Image Available</div>
                        }
                    </div>

                    <div class="p-3 bg-white mt-auto">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h3 class="fw-bold m-0" style="font-size: 0.9rem; text-transform: uppercase;">
                                <a asp-controller="Products" asp-action="Details" asp-route-id="@item.Id" class="text-dark text-decoration-none">@item.Name</a>
                            </h3>
                            <span class="fw-bold text-nowrap ms-2" style="font-size: 0.9rem;">Rs. @item.Price.ToString("N2")</span>
                        </div>
                        
                        <p class="text-muted text-truncate-2 m-0" style="font-size: 0.75rem; line-height: 1.4; height: 2.8em; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                            @item.Description
                        </p>

                        <div class="mt-3 pt-2 border-top d-flex justify-content-between match-actions-style" style="font-size: 0.75rem;">
                            <span class="text-muted">Stock: @item.Stock</span>
                            <div>
                                <a asp-controller="Products" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark me-2 fw-bold">Details</a>
                                <a asp-controller="Products" asp-action="Edit" asp-route-id="@item.Id" class="text-decoration-none text-warning me-2">Edit</a>
                                <a asp-controller="Products" asp-action="Delete" asp-route-id="@item.Id" class="text-decoration-none text-danger">Delete</a>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>
</div>