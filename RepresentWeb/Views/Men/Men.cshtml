@model IEnumerable<representweb.Models.Product>

@{
    ViewData["Title"] = "Men Products";
}

<h2>Men Products</h2>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-body">
                    <h5>@item.Name</h5>
                    <p>@item.Description</p>
                    <p><strong>@item.Price</strong></p>
                </div>
            </div>
        </div>
    }
</div>