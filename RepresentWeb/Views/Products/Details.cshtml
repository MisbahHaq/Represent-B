@model RepresentWeb.Models.Product
@using RepresentWeb.Models

@{
    ViewData["Title"] = Model.Name;
    var images = Model.GetImages() ?? new List<string> { "" };
}

@section Head {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
}

<style>
    #relatedSwiper { overflow: hidden; }
    #relatedSwiper .swiper-slide a { text-decoration: none !important; color: inherit; display: block; }
    #relatedSwiper .swiper-slide a:hover { text-decoration: none !important; color: inherit; }
    .swiper-button-next, .swiper-button-prev { color: #fff; }
</style>

<div class="bg-white">
    <div class="container-fluid px-0" style="max-width: 1600px;">

        <div class="row gx-0 gy-5">

            <div class="col-12 col-lg-6 px-0">
                <div class="img-container aspect-portrait animate-fade-in"
                     style="background: #f7f7f5; max-height: 85vh;">

                    @if (!string.IsNullOrEmpty(images.FirstOrDefault()))
                    {
                        <img src="@images.FirstOrDefault()"
                             alt="@Model.Name"
                             id="mainProductImage"
                             style="object-fit: contain; padding: 2rem; transition: opacity 0.5s ease;" />
                    }
                    else
                    {
                        <div class="w-100 h-100 d-flex align-items-center justify-content-center text-muted"
                             style="font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase;">
                            No Image Available
                        </div>
                    }
                </div>

                @if (images.Count > 1)
                {
                    <div class="d-flex gap-2 mt-3 px-4">
                        @for (int i = 0; i < Math.Min(3, images.Count); i++)
                        {
                            <div class="img-container cursor-pointer"
                                 style="width: 75px; height: 90px; background: #f5f5f3; aspect-ratio: 3/4;"
                                 onclick="switchImage('@images[i]', this)">
                                <img src="@images[i]"
                                     alt="Thumbnail @(i + 1)"
                                     class="w-100 h-100"
                                     style="object-fit: contain; padding: 0.3rem;" />
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="col-12 col-lg-5 offset-lg-1 d-flex flex-column justify-content-center"
                 style="padding: 2rem clamp(1.5rem, 4vw, 4rem);">

                <div class="animate-fade-in animate-delay-1">

                    <div class="d-flex justify-content-between align-items-start mb-1">
                        <h1 class="text-primary m-0"
                            style="color: #1a1a1a !important; font-size: clamp(1.3rem, 2vw, 1.6rem); font-weight: 300; letter-spacing: 0.06em; text-transform: uppercase; line-height: 1.3;">
                            @Model.Name
                        </h1>

                        <button class="bookmark-btn p-0 border-0 bg-transparent"
                                onclick="toggleBookmark(event, @Model.Id)"
                                id="productBookmarkBtn"
                                data-bookmarked="false"
                                style="cursor: pointer; transition: color 0.5s ease;"
                                title="Save Item">
                            <i class="bi bi-bookmark" style="font-size: 1.1rem;"></i>
                        </button>
                    </div>

                    <div class="mt-4 mb-5"
                         style="font-size: 1.15rem; font-weight: 300; letter-spacing: 0.04em;">
                        Rs @Model.Price.ToString("N2")
                    </div>

                </div>

                <div class="mb-5 animate-fade-in animate-delay-2" id="sizeSection">
                    <p class="text-caption mb-3" style="color: #999;">Select Size</p>
                    <div class="row gx-2" id="sizeSelectorGroup">
                        <div class="col-3">
                            <button type="button" class="btn-minimal w-100 py-3 size-btn" data-size="S"
                                    style="font-size: 0.75rem; min-width: auto; padding: 0.7rem 0;">
                                S
                            </button>
                        </div>
                        <div class="col-3">
                            <button type="button" class="btn-minimal w-100 py-3 size-btn" data-size="M"
                                    style="font-size: 0.75rem; min-width: auto; padding: 0.7rem 0;">
                                M
                            </button>
                        </div>
                        <div class="col-3">
                            <button type="button" class="btn-minimal w-100 py-3 size-btn" data-size="L"
                                    style="font-size: 0.75rem; min-width: auto; padding: 0.7rem 0;">
                                L
                            </button>
                        </div>
                        <div class="col-3">
                            <button type="button" class="btn-minimal w-100 py-3 size-btn" data-size="XL"
                                    style="font-size: 0.75rem; min-width: auto; padding: 0.7rem 0;">
                                XL
                            </button>
                        </div>
                    </div>
                </div>

                <div class="mb-6 animate-fade-in animate-delay-3">
                    <button id="addToBagCta" class="btn-minimal btn-filled w-100 py-3"
                            style="font-size: 0.72rem; letter-spacing: 0.2em;">
                        Select A Size
                    </button>
                </div>

                <div class="animate-fade-in animate-delay-4" style="font-size: 0.8rem; font-weight: 300; color: #888; line-height: 2.2;">
                    <p style="margin-bottom: 0.25rem;">Model is 184.5cm and 72kg wearing size M</p>
                    <p style="margin-bottom: 0.25rem;">Earn 240 Prestige Points</p>
                    <p style="margin-bottom: 0.25rem;">Free Shipping Over $300</p>
                    <p>In Stock (@Model.Stock units available)</p>
                </div>

                <hr class="divider">

                <div class="accordion accordion-flush animate-fade-in animate-delay-4" id="productMetaAccordion">
                    <div class="accordion-item" style="border-bottom: 1px solid #eee;">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed px-0 py-3 text-primary bg-transparent text-start"
                                    type="button" data-bs-toggle="collapse" data-bs-target="#collapseDetails"
                                    style="font-size: 0.78rem; font-weight: 400; letter-spacing: 0.08em; text-transform: uppercase;">
                                Product Details
                            </button>
                        </h2>
                        <div id="collapseDetails" class="accordion-collapse collapse"
                             data-bs-parent="#productMetaAccordion">
                            <div class="px-0 pb-4 text-secondary" style="font-size: 0.82rem; font-weight: 300; line-height: 1.8; color: #666;">
                                @if(!string.IsNullOrEmpty(Model.Description)) {
                                    @Model.Description
                                } else {
                                    <text>Introducing the All Over Print Towel Shirt in Aged White, crafted from heavyweight 300GSM reverse towelling cotton. Designed with a standard fit and revere collar, this shirt delivers relaxed vacation energy with a textured twist. Finished with side splits at the hem for ease of wear.</text>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item" style="border-bottom: 1px solid #eee;">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed px-0 py-3 text-primary bg-transparent text-start"
                                    type="button" data-bs-toggle="collapse" data-bs-target="#collapseShipping"
                                    style="font-size: 0.78rem; font-weight: 400; letter-spacing: 0.08em; text-transform: uppercase;">
                                Shipping & Returns
                            </button>
                        </h2>
                        <div id="collapseShipping" class="accordion-collapse collapse"
                             data-bs-parent="#productMetaAccordion">
                            <div class="px-0 pb-4 text-secondary" style="font-size: 0.82rem; font-weight: 300; line-height: 1.8; color: #666;">
                                Free shipping on orders over $300. Standard delivery takes 3-5 business days. Express delivery available. Free returns within 30 days.
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <div class="bg-secondary" style="padding: 5rem 0; margin-top: 4rem;">
        <div class="container-fluid" style="max-width: 1500px; padding: 0 clamp(1.5rem, 5vw, 5rem);">
            <p class="text-caption mb-5 animate-fade-in" style="color: #999; letter-spacing: 0.2em;">
                You Might Also Like
            </p>

            @if (ViewBag.RelatedProducts is List<RepresentWeb.Models.Product> relatedProducts && relatedProducts.Any())
            {
                <div class="swiper" id="relatedSwiper" style="overflow: hidden;">
                    <div class="swiper-wrapper">
                        @foreach (var relatedProduct in relatedProducts)
                        {
                            var relatedImages2 = relatedProduct.GetImages() ?? new List<string> { "" };
                            var relatedProductImage2 = relatedImages2.FirstOrDefault() ?? "";
                            
                            <div class="swiper-slide" style="height: auto;">
                                <a asp-controller="Products" asp-action="Details" asp-route-id="@relatedProduct.Id">
                                    <div class="img-container aspect-square mb-3" style="background: #efedea;">
                                        @if (!string.IsNullOrEmpty(relatedProductImage2))
                                        {
                                            <img src="@relatedProductImage2" alt="@relatedProduct.Name" class="w-100 h-100"
                                                 style="object-fit: contain; padding: 1rem;" />
                                        }
                                        else
                                        {
                                            <div class="w-100 h-100 d-flex align-items-center justify-content-center"
                                                 style="font-size: 0.7rem; color: #bbb; letter-spacing: 0.12em; text-transform: uppercase;">
                                                Product
                                            </div>
                                        }
                                    </div>
                                    <p class="m-0" style="font-size: 0.78rem; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: #1a1a1a;">
                                        @relatedProduct.Name
                                    </p>
                                    <p class="m-0 mt-1" style="font-size: 0.75rem; font-weight: 300; color: #999;">Rs @relatedProduct.Price.ToString("N2")</p>
                                </a>
                            </div>
                        }
                    </div>
                    <div class="swiper-button-prev" id="relatedPrev"></div>
                    <div class="swiper-button-next" id="relatedNext"></div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

    <script>
        function switchImage(src, thumbnailEl) {
            const mainImg = document.getElementById('mainProductImage');
            if (!mainImg || !src) return;
            mainImg.style.opacity = '0';
            setTimeout(() => {
                mainImg.src = src;
                mainImg.style.opacity = '1';
            }, 250);
        }

        function isUserLoggedIn() {
            if (typeof appAuthCache !== 'undefined' && appAuthCache !== null) return Promise.resolve(appAuthCache);
            if (typeof window.appAuthCache !== 'undefined' && window.appAuthCache !== null) return Promise.resolve(window.appAuthCache);
            return fetch('/Account/CheckAuth')
                .then(r => r.json())
                .then(data => {
                    window.appAuthCache = data.authenticated;
                    return data.authenticated;
                })
                .catch(() => false);
        }

        function showLoginPrompt() {
             const result = confirm('Please log in to use the bookmark feature.\n\nOK to go to login page, Cancel to stay on current page.');
             if (result) { window.location.href = '/Account/Login'; }
         }

        function setBookmarkButtonState(btn, isBookmarked) {
            btn.dataset.bookmarked = isBookmarked ? 'true' : 'false';
            btn.style.color = isBookmarked ? '#000' : '#999';
            btn.classList.toggle('is-bookmarked', isBookmarked);
            const icon = btn.querySelector('i');
            if (icon) {
                icon.classList.toggle('bi-bookmark-fill', isBookmarked);
                icon.classList.toggle('bi-bookmark', !isBookmarked);
            }
        }

        function toggleBookmark(event, productId) {
            const btn = event.currentTarget || event.target.closest('.bookmark-btn');
            if (!btn) return;
            isUserLoggedIn().then(loggedIn => {
                if (!loggedIn) { showLoginPrompt(); return; }
                const isBookmarked = btn.dataset.bookmarked === 'true' || btn.classList.contains('is-bookmarked');
                const url = isBookmarked ? '/Bookmark/Remove/' + productId : '/Bookmark/Add/' + productId;
                btn.disabled = true;
                fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': getAntiForgeryToken(),
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: 'id=' + productId
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        const nextBookmarkedState = !isBookmarked;
                        setBookmarkButtonState(btn, nextBookmarkedState);
                        updateBookmarkCount();
                    const bookmarkId = String(productId);
                    const saved = localStorage.getItem('bookmarkedProducts') || '[]';
                    let bookmarks = JSON.parse(saved).map(id => String(id));
                    if (nextBookmarkedState) { if (!bookmarks.includes(bookmarkId)) bookmarks.push(bookmarkId); }
                    else { const idx = bookmarks.indexOf(bookmarkId); if (idx > -1) bookmarks.splice(idx, 1); }
                    localStorage.setItem('bookmarkedProducts', JSON.stringify(bookmarks));
                    } else { alert('Failed to update bookmark'); }
                    btn.disabled = false;
                })
                .catch(error => { console.error('Error:', error); alert('Network error'); btn.disabled = false; });
            });
        }

        function updateBookmarkCount() {
            fetch('/Bookmark/GetCount').then(r => r.json()).then(data => {
                const badge = document.querySelector('#bookmarkLink .badge-count');
                if (badge) {
                    badge.textContent = data.count;
                    badge.style.display = data.count > 0 ? 'inline-block' : 'none';
                }
            });
        }
        
        function updateCartCount() {
            fetch('/Cart/GetCount').then(r => r.json()).then(data => {
                const el = document.querySelector('#cartLink .badge-count');
                if (el) el.textContent = data.count;
            });
        }
        
        function getAntiForgeryToken() {
            const tokenElement = document.querySelector('[name=__RequestVerificationToken]');
            return tokenElement ? tokenElement.value : '';
        }

        document.addEventListener('DOMContentLoaded', function () {
            const sizeButtons = document.querySelectorAll('.size-btn');
            const ctaButton = document.getElementById('addToBagCta');
            sizeButtons.forEach(button => {
                button.addEventListener('click', function () {
                    sizeButtons.forEach(btn => {
                        btn.classList.remove('btn-filled');
                        btn.style.background = 'transparent';
                        btn.style.color = '#1a1a1a';
                    });
                    this.classList.add('btn-filled');
                    this.style.background = '#1a1a1a';
                    this.style.color = '#fff';
                    const selectedSize = this.getAttribute('data-size');
                    ctaButton.innerText = 'ADD TO BAG ・ SIZE ' + selectedSize;
                });
            });
            ctaButton.addEventListener('click', function() {
                const selectedSize = document.querySelector('.size-btn.btn-filled')?.getAttribute('data-size');
                if (!selectedSize) { alert('Please select a size first'); return; }
                const originalText = this.innerText;
                this.innerText = 'Adding...'; this.disabled = true;
                fetch('/Cart/Add/@Model.Id', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': getAntiForgeryToken(),
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: 'id=@Model.Id&quantity=1'
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        this.innerText = 'Added to Bag';
                        updateCartCount();
                        setTimeout(() => { this.innerText = originalText; this.disabled = false; }, 2000);
                    } else { alert('Failed to add item to cart'); this.innerText = originalText; this.disabled = false; }
                })
                .catch(error => { alert('Network error'); this.innerText = originalText; this.disabled = false; });
            });
            const saved = localStorage.getItem('bookmarkedProducts') || '[]';
            const bookmarks = JSON.parse(saved).map(id => String(id));
            if (bookmarks.includes(String(@Model.Id))) {
                const btn = document.getElementById('productBookmarkBtn');
                if (btn) {
                    setBookmarkButtonState(btn, true);
                }
            }
            updateBookmarkCount();
            
            // Swiper Initialization
            new Swiper('#relatedSwiper', {
                slidesPerView: 4,
                spaceBetween: 24,
                centeredSlides: false,
                loop: true,
                navigation: {
                    nextEl: '#relatedNext',
                    prevEl: '#relatedPrev',
                },
                breakpoints: {
                    0: { slidesPerView: 2, spaceBetween: 16 },
                    768: { slidesPerView: 3, spaceBetween: 20 },
                    1200: { slidesPerView: 4, spaceBetween: 24 }
                }
            });
        });
    </script>
}