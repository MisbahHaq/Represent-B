@model representweb.Models.Product

@{
    ViewData["Title"] = Model.Name;
    var images = Model.GetImages() ?? new List<string> { "" };
}

<div class="container-fluid pt-0 pb-4 bg-white" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; letter-spacing: 0.3px;">
    <div class="row g-0 g-md-5">
        
        <div class="col-12 col-md-6 px-0">
            <div class="position-relative d-flex align-items-start justify-content-start mb-4 bg-light" style="max-height: 600px; overflow: hidden;">
                @if (!string.IsNullOrEmpty(images.FirstOrDefault()))
                {
<div id="productCarousel" class="carousel slide w-100" data-bs-ride="false">
    <div class="carousel-inner">
        @for (int i = 0; i < images.Count; i++)
        {
            <div class="carousel-item @(i == 0 ? "active" : "")">
                <img src="@images[i]" alt="@Model.Name" class="d-block w-100" style="max-height: 600px; object-fit: contain;" />
            </div>
        }
    </div>
    @if (images.Count > 1)
    {
        <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
        </button>
    }
</div>
                }
                else
                {
                    <span class="text-muted">No Image Available</span>
                }
            </div>

            <div class="row g-2 d-none d-md-flex mt-2">
                @for (int i = 0; i < Math.Min(3, images.Count); i++)
                {
                    <div class="col-4">
                        <div class="w-100 d-flex align-items-center justify-content-center bg-light thumbnail-selector" data-slide-to="@i" style="height: 180px; overflow: hidden; cursor: pointer; border: 1px solid transparent; transition: border-color 0.2s;">
                            @if (!string.IsNullOrEmpty(images[i]))
                            {
                                <img src="@images[i]" alt="@Model.Name" class="w-100 h-100 object-fit-cover" />
                            }
                            else
                            {
                                <span class="text-muted small">Image @(i + 1)</span>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="col-12 col-md-6 ps-md-4">
            <div class="d-flex justify-content-between align-items-start mb-1">
                <h1 class="fw-normal text-dark m-0" style="font-size: 1.65rem; font-weight: 500; letter-spacing: 0.5px;">@Model.Name</h1>
                
                <button class="btn p-0 border-0 bg-transparent text-muted mt-1 bookmark-btn" onclick="toggleBookmark(event, @Model.Id)" style="cursor: pointer;" title="Save Item">
                    <svg width="16" height="20" viewBox="0 0 16 20" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
                        <path d="M1 1H15V19L8 14L1 19V1Z" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
            </div>
            
            <div class="h4 fw-bold mb-4 text-dark" style="font-size: 1.3rem;">
                Rs @Model.Price.ToString("N2")
            </div>

            <p class="text-muted mb-3" style="font-size: 0.8rem;">
                Model is 184.5cm and 72kg wearing size M <a href="#" class="text-dark text-decoration-underline ms-1">Size & Fit Guide</a>
            </p>

            <div class="row gx-2 mb-3" id="sizeSelectorGroup">
                <div class="col-3">
                    <button type="button" class="btn btn-outline-dark w-100 py-2 rounded-0 text-uppercase fw-semibold size-btn" data-size="S" style="font-size: 0.85rem;">S</button>
                </div>
                <div class="col-3">
                    <button type="button" class="btn btn-outline-dark w-100 py-2 rounded-0 text-uppercase fw-semibold size-btn" data-size="M" style="font-size: 0.85rem;">M</button>
                </div>
                <div class="col-3">
                    <button type="button" class="btn btn-outline-dark w-100 py-2 rounded-0 text-uppercase fw-semibold size-btn" data-size="L" style="font-size: 0.85rem;">L</button>
                </div>
                <div class="col-3">
                    <button type="button" class="btn btn-outline-dark w-100 py-2 rounded-0 text-uppercase fw-semibold size-btn" data-size="XL" style="font-size: 0.85rem;">XL</button>
                </div>
            </div>

            <button id="addToBagCta" class="btn w-100 py-3 rounded-0 fw-bold border-0 text-uppercase mb-4" style="background-color: #111827; color: white; letter-spacing: 1px; font-size: 0.85rem;">
                Select A Size
            </button>

            <div class="d-grid gap-2 mt-3">
                <button id="addToCartBtn" class="btn btn-outline-dark w-100" style="font-size: 0.85rem;">
                    <i class="bi bi-bag-plus me-2"></i> Add to Cart
                </button>
            </div>

            <ul class="list-unstyled mb-4 pb-2 border-bottom text-start" style="font-size: 0.8rem; line-height: 1.8;">
                <li class="text-muted"><span class="me-2">&#9679;</span> EARN 240 PRESTIGE POINTS</li>
                <li class="text-success"><span class="me-2">&#9679;</span> FREE SHIPPING OVER $300</li>
                <li class="text-success"><span class="me-2">&#9679;</span> IN STOCK (Current Available: @Model.Stock units)</li>
            </ul>

            <div class="accordion accordion-flush border-bottom" id="productMetaAccordion">
                
                <div class="accordion-item border-0">
                    <h2 class="accordion-header" id="headingDetails">
                        <button class="accordion-button collapsed px-0 py-3 fw-bold text-dark bg-white text-start" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDetails" aria-expanded="false" aria-controls="collapseDetails" style="font-size: 0.85rem;">
                            Product Details
                        </button>
                    </h2>
<div id="collapseDetails" class="accordion-collapse collapse" aria-labelledby="headingDetails" data-bs-parent="#productMetaAccordion">
    <div class="accordion-body px-0 pt-1 pb-3 text-muted text-start" style="font-size: 0.85rem; line-height: 1.6; display: block;">
                            @if(!string.IsNullOrEmpty(Model.Description)) {
                                @Model.Description
                            } else {
                                <text>Introducing the All Over Print Towel Shirt in Aged White, crafted from heavyweight 300GSM reverse towelling cotton. Designed with a standard fit and revere collar, this shirt delivers relaxed vacation energy with a textured twist. The standout feature is its tonal all-over towelling logo pattern, offering depth and subtle visual contrast. Finished with side splits at the hem for ease of wear.</text>
                            }
                        </div>
                    </div>
                </div>

                <div class="accordion-item border-0">
                    <h2 class="accordion-header" id="headingShipping">
                        <button class="accordion-button collapsed px-0 py-3 fw-bold text-dark bg-white text-start" type="button" data-bs-toggle="collapse" data-bs-target="#collapseShipping" aria-expanded="false" aria-controls="collapseShipping" style="font-size: 0.85rem;">
                            Shipping & Returns
                        </button>
                    </h2>
<div id="collapseShipping" class="accordion-collapse collapse" aria-labelledby="headingShipping" data-bs-parent="#productMetaAccordion">
    <div class="accordion-body px-0 pt-1 pb-3 text-muted text-start" style="font-size: 0.85rem; line-height: 1.6; display: block;">
                            Free shipping on orders over $300. Standard delivery takes 3-5 business days. Express delivery available. Free returns within 30 days.
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <div class="mt-5 pt-5 text-center border-top">
        <h4 class="fw-bold text-uppercase mb-1" style="font-size: 1rem; letter-spacing: 1.5px;">You Might Also Like</h4>
        <p class="text-muted small mb-4">Discover more products from our collection</p>
        
        <div class="row g-3 justify-content-center">
            <div class="col-6 col-md-2">
                <div class="p-3 mb-2" style="background-color: #f6f6f6; min-height: 160px;"></div>
                <div class="small fw-bold text-uppercase" style="font-size: 0.7rem;">247 Bucket Hat</div>
            </div>
            <div class="col-6 col-md-2">
                <div class="p-3 mb-2" style="background-color: #f6f6f6; min-height: 160px;"></div>
                <div class="small fw-bold text-uppercase" style="font-size: 0.7rem;">Legacy Hoodie</div>
            </div>
            <div class="col-6 col-md-2">
                <div class="p-3 mb-2" style="background-color: #f6f6f6; min-height: 160px;"></div>
                <div class="small fw-bold text-uppercase" style="font-size: 0.7rem;">Utility Shoulder Bag</div>
            </div>
            <div class="col-6 col-md-2">
                <div class="p-3 mb-2" style="background-color: #f6f6f6; min-height: 160px;"></div>
                <div class="small fw-bold text-uppercase" style="font-size: 0.7rem;">Overdrive Leather Jacket</div>
            </div>
        </div>
    </div>
</div>

    <script>
        function isUserLoggedIn() {
            // Check if user is logged in by looking for token or user info in localStorage
            // In a real app, this would check for a valid JWT token or session
            const token = localStorage.getItem('authToken');
            return token !== null && token !== '';
        }

        function showLoginPrompt() {
            // Show a login prompt - in a real app, this would redirect to login page or show modal
            alert('Please log in to use the bookmark feature.');
            // Optionally redirect to login page:
            // window.location.href = '/Account/Login';
        }

        function toggleBookmark(event, productId) {
            // Check if user is logged in before allowing bookmark action
            if (!isUserLoggedIn()) {
                showLoginPrompt();
                return;
            }

            const btn = event.currentTarget;
            const isBookmarked = btn.classList.contains('text-dark');
            const url = isBookmarked ? '/Bookmark/Remove/' + productId : '/Bookmark/Add/' + productId;

            // Disable button during request
            btn.disabled = true;

            fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': getAntiForgeryToken(),
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: 'id=' + productId
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Toggle button state
                    btn.classList.toggle('text-dark');
                    // Update bookmark count in header
                    updateBookmarkCount();
                    // Update localStorage to keep in sync
                    const saved = localStorage.getItem('bookmarkedProducts') || '[]';
                    let bookmarks = JSON.parse(saved);
                    if (isBookmarked) {
                        const index = bookmarks.indexOf(productId);
                        if (index > -1) bookmarks.splice(index, 1);
                    } else {
                        if (!bookmarks.includes(productId)) bookmarks.push(productId);
                    }
                    localStorage.setItem('bookmarkedProducts', JSON.stringify(bookmarks));
                } else {
                    alert('Failed to update bookmark');
                }
                btn.disabled = false;
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Network error');
                btn.disabled = false;
            });
        }

        // Helper functions for cart
        function getAntiForgeryToken() {
            const tokenElement = document.querySelector('[name=__RequestVerificationToken]');
            return tokenElement ? tokenElement.value : '';
        }

        function updateCartCount() {
            fetch('/Cart/GetCount')
                .then(response => response.json())
                .then(data => {
                    // Update cart count in header if exists
                    const cartBadge = document.querySelector('.badge');
                    if (cartBadge) {
                        cartBadge.textContent = data.count;
                    }
                });
        }

        document.addEventListener('DOMContentLoaded', function () {
            const sizeButtons = document.querySelectorAll('.size-btn');
            const ctaButton = document.getElementById('addToBagCta');
            const bookmarkBtn = document.querySelector('.bookmark-btn');
            const thumbnails = document.querySelectorAll('.thumbnail-selector');
            
            const carouselEl = document.getElementById('productCarousel');
            let productCarousel = null;
            if(carouselEl && typeof bootstrap !== 'undefined') {
                productCarousel = new bootstrap.Carousel(carouselEl);
            }
 
            if(thumbnails.length > 0) {
                thumbnails[0].style.borderColor = '#111827';
            }
 
            thumbnails.forEach(thumb => {
                thumb.addEventListener('click', function() {
                    const targetSlideIndex = parseInt(this.getAttribute('data-slide-to'));
                    
                    if(productCarousel) {
                        productCarousel.to(targetSlideIndex);
                    }
                    
                    thumbnails.forEach(t => t.style.borderColor = 'transparent');
                    this.style.borderColor = '#111827';
                });
            });
 
            if (carouselEl) {
                carouselEl.addEventListener('slide.bs.carousel', function (event) {
                    thumbnails.forEach(t => t.style.borderColor = 'transparent');
                    if(thumbnails[event.to]) {
                        thumbnails[event.to].style.borderColor = '#111827';
                    }
                });
            }
 
            sizeButtons.forEach(button => {
                button.addEventListener('click', function () {
                    sizeButtons.forEach(btn => {
                        btn.style.backgroundColor = 'transparent';
                        btn.style.color = '#212529';
                    });
 
                    this.style.backgroundColor = '#111827';
                    this.style.color = '#ffffff';
 
                    const selectedSize = this.getAttribute('data-size');
                    ctaButton.innerText = 'ADD TO BAG - SIZE ' + selectedSize;
                    ctaButton.style.backgroundColor = '#111827';
                });
            });

            // Add to cart functionality
            const addToCartBtn = document.getElementById('addToCartBtn');
            if (addToCartBtn) {
                addToCartBtn.addEventListener('click', function() {
                    const selectedSize = document.querySelector('.size-btn.active')?.getAttribute('data-size') || 'M';
                    const quantity = 1; // Default quantity
                    
                    // Show loading state
                    const originalText = this.innerHTML;
                    this.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Adding...';
                    this.disabled = true;
                    
                     fetch('/Cart/Add/' + @Model.Id, {
                         method: 'POST',
                         headers: {
                             'Content-Type': 'application/x-www-form-urlencoded',
                             'RequestVerificationToken': getAntiForgeryToken(),
                             'X-Requested-With': 'XMLHttpRequest'
                         },
                         body: 'id=' + @Model.Id + '&quantity=' + quantity
                     })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            // Show success feedback
                            this.innerHTML = '<i class="bi bi-check-circle me-2"></i> Added!';
                            this.classList.remove('btn-outline-dark');
                            this.classList.add('btn-success');
                            
                            // Update cart count in header
                            updateCartCount();
                            
                            // Reset button after 2 seconds
                            setTimeout(() => {
                                this.innerHTML = originalText;
                                this.classList.remove('btn-success');
                                this.classList.add('btn-outline-dark');
                                this.disabled = false;
                            }, 2000);
                        } else {
                            alert('Failed to add item to cart');
                            this.innerHTML = originalText;
                            this.disabled = false;
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('Network error');
                        this.innerHTML = originalText;
                        this.disabled = false;
                    });
                });
            }

            const saved = localStorage.getItem('bookmarkedProducts') || '[]';
            const bookmarks = JSON.parse(saved);
            if (bookmarks.includes(@Model.Id)) {
                bookmarkBtn?.classList.add('text-dark');
            }
        });
    </script>