@model RepresentWeb.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="section-spacer bg-white">
    <div class="container-fluid text-center" style="max-width: 520px; padding: 0 clamp(1.5rem, 4vw, 4rem); margin: 0 auto;">

        <div class="animate-fade-in" style="padding: 4rem 0;">
            <p class="text-caption animate-fade-in animate-delay-1" style="color: #999;">
                @ViewData["Title"]
            </p>
            <h1 class="animate-fade-in animate-delay-2"
                style="font-size: clamp(3rem, 6vw, 5rem); font-weight: 200; letter-spacing: 0.06em; text-transform: uppercase; color: #1a1a1a; margin-top: 0.5rem; line-height: 1;">
                500
            </h1>
            <p class="animate-fade-in animate-delay-3"
               style="font-size: 0.85rem; font-weight: 300; color: #888; margin-top: 1rem; line-height: 1.7;">
                Something went wrong on our end. Please try again shortly.
            </p>
            <a asp-controller="Home" asp-action="Index"
               class="btn-minimal animate-fade-in animate-delay-4"
               style="margin-top: 2.5rem;">
                Return Home
            </a>
        </div>

    </div>
</div>
