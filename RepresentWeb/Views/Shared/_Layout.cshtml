<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"] - RepresentWeb</title>
  <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/RepresentWeb.styles.css" asp-append-version="true" />
</head>

<style>
  .nav-link-minimal {
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #fff;
    text-decoration: none;
    padding: 0;
    opacity: 0.75;
    transition: opacity 0.5s ease;
  }
  .nav-link-minimal:hover { opacity: 1; color: #fff; }
  .badge-count {
    font-size: 0.6rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    padding: 0.3em 0.55em;
    border-radius: 0;
    background: #1a1a1a;
    color: #fff;
    min-width: 18px;
    text-align: center;
    line-height: 1;
  }
  .icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    opacity: 0.75;
    transition: opacity 0.5s ease;
    color: #fff;
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
  }
  .icon-btn:hover { opacity: 1; color: #fff; }

  #searchWrap {
    display: flex;
    align-items: center;
    overflow: hidden;
    max-width: 0;
    transition: max-width 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.25s ease;
    opacity: 0;
  }
  #searchWrap.open {
    max-width: 220px;
    opacity: 1;
  }
  #searchWrap input {
    width: 200px;
    font-size: 0.75rem;
    border-radius: 0;
    border: none;
    background: rgba(255,255,255,0.1);
    color: #fff;
  }
  #searchWrap input::placeholder { color: rgba(255,255,255,0.5); }
  #searchSuggestions {
    position: absolute;
    top: 100%;
    right: 0;
    left: auto;
    width: 260px;
    background: #111;
    border: 1px solid #333;
    z-index: 1050;
    display: none;
    max-height: 320px;
    overflow-y: auto;
  }
  #searchSuggestions .suggestion-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.85rem;
    color: #ccc;
    text-decoration: none;
    font-size: 0.78rem;
    border-bottom: 1px solid #1f1f1f;
    transition: background 0.2s ease, color 0.2s ease;
  }
  #searchSuggestions .suggestion-item:last-child { border-bottom: none; }
  #searchSuggestions .suggestion-item:hover {
    background: #1a1a1a;
    color: #fff;
  }
  #searchSuggestions .suggestion-item img {
    width: 36px;
    height: 36px;
    object-fit: cover;
    border-radius: 0;
    flex-shrink: 0;
    background: #222;
  }
  #searchSuggestions .suggestion-meta {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }
  #searchSuggestions .suggestion-name {
    color: #fff;
    font-weight: 400;
    letter-spacing: 0.04em;
  }
  #searchSuggestions .suggestion-price {
    color: #888;
    font-size: 0.7rem;
  }
  #searchSuggestions .no-results {
    padding: 0.75rem 0.85rem;
    color: #666;
    font-size: 0.75rem;
    font-style: italic;
  }
</style>

<body>
    <div style="display:none">
        @Html.AntiForgeryToken()
    </div>
   <header>

    <nav class="navbar navbar-expand-lg navbar-dark bg-black border-bottom border-secondary py-3">
      <div class="container-fluid px-4 d-flex align-items-center justify-content-between">

          <!-- LEFT -->
          <div class="d-none d-md-flex align-items-center" style="gap: 2.8rem;">

            <a class="nav-link-minimal" asp-controller="Home" asp-action="Men">Men</a>
            <a class="nav-link-minimal" asp-controller="Home" asp-action="Women">Women</a>

          </div>

<!-- CENTER -->
          <a class="navbar-brand position-absolute start-50 translate-middle-x text-white m-0"
             asp-controller="Home" asp-action="Index"
             style="letter-spacing: 0.35em; font-size: 0.9rem; font-weight: 200; text-transform: uppercase;">
            Represent
          </a>

           <!-- RIGHT -->
           <div class="d-flex align-items-center" style="gap: 2.2rem;">

             <a class="nav-link-minimal d-none d-md-block" asp-action="Vault" asp-controller="Home">The Vault</a>

             <div class="d-flex align-items-center" style="position: relative; gap: 0;">

               <button type="button" class="icon-btn" id="searchToggle" aria-label="Search" style="flex-shrink: 0;">
                 <i class="bi bi-search" style="font-size: 0.95rem;"></i>
               </button>

               <div id="searchWrap">
                 <form asp-controller="Home" asp-action="Search" method="get" id="searchForm" class="d-flex align-items-center" style="gap: 0.4rem;">
                   <input type="text" name="q" id="searchInput" class="form-control" placeholder="Search..."
                          autocomplete="off" />
                 </form>
                 <div id="searchSuggestions"></div>
               </div>

             </div>

      <a href="#" class="icon-btn" id="userLoginLink">
      <i class="bi bi-person" style="font-size: 0.95rem;"></i>
    </a>

            <a asp-controller="Bookmark" asp-action="Index" class="icon-btn position-relative" id="bookmarkLink">
              <i class="bi bi-bookmark bookmark-icon" style="font-size: 0.95rem; color: #fff; transition: color 0.5s ease;"></i>
              <span class="badge-count position-absolute"
                    style="top: -6px; right: -8px; display: none;">0</span>
            </a>

             <a asp-controller="Cart" asp-action="Index" class="icon-btn position-relative" id="cartLink">
              <i class="bi bi-bag" style="font-size: 0.95rem;"></i>
              <span class="badge-count position-absolute"
                    style="top: -4px; right: -8px;">0</span>
            </a>

          </div>

      </div>
    </nav>

  </header>

  <main role="main" class="pb-0">
    @RenderBody()
  </main>

  <footer class="bg-dark text-white" style="padding-top: 5rem; padding-bottom: 3rem;">
    <div class="container-fluid px-4 px-lg-5" style="max-width: 1400px;">

      <div class="row g-4 gx-0" style="border-top: 1px solid #222; padding-top: 3rem;">

        <div class="col-12 col-lg-4 mb-4 mb-lg-0">
          <h2 class="m-0 mb-4"
              style="font-size: 0.85rem; font-weight: 200; letter-spacing: 0.35em; text-transform: uppercase;">
            Represent
          </h2>

          <p class="m-0" style="max-width: 340px; font-size: 0.8rem; font-weight: 300; color: #777; line-height: 1.8; letter-spacing: 0.03em;">
            Sign up to receive exclusive access to new drops, restocks and members-only releases.
          </p>
        </div>

        <div class="col-6 col-lg-2 offset-lg-1">
          <p class="text-caption mb-3" style="color: #555;">Help</p>
          <ul class="list-unstyled" style="font-size: 0.78rem; font-weight: 300; color: #888; line-height: 2.2;">
            <li><a href="#" class="text-decoration-none hover-fade" style="color: #888;">Contact</a></li>
            <li><a href="#" class="text-decoration-none hover-fade" style="color: #888;">Shipping</a></li>
            <li><a href="#" class="text-decoration-none hover-fade" style="color: #888;">Returns</a></li>
            <li><a href="#" class="text-decoration-none hover-fade" style="color: #888;">FAQs</a></li>
            <li><a href="#" class="text-decoration-none hover-fade" style="color: #888;">Privacy Policy</a></li>
          </ul>
        </div>

        <div class="col-6 col-lg-2">
          <p class="text-caption mb-3" style="color: #555;">Connect</p>
          <ul class="list-unstyled" style="font-size: 0.78rem; font-weight: 300; color: #888; line-height: 2.2;">
            <li><a href="#" class="text-decoration-none hover-fade" style="color: #888;">Instagram</a></li>
            <li><a href="#" class="text-decoration-none hover-fade" style="color: #888;">Twitter / X</a></li>
            <li><a href="#" class="text-decoration-none hover-fade" style="color: #888;">YouTube</a></li>
            <li><a href="#" class="text-decoration-none hover-fade" style="color: #888;">TikTok</a></li>
          </ul>
        </div>

        <div class="col-12 mt-5 pt-4">
          <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <p class="text-caption m-0" style="color: #444;">© 2026 Represent. All rights reserved.</p>
            <div class="d-flex gap-4">
              <a href="#" class="text-decoration-none text-caption hover-fade" style="color: #555;">Terms</a>
              <a href="#" class="text-decoration-none text-caption hover-fade" style="color: #555;">Privacy</a>
              <a href="#" class="text-decoration-none text-caption hover-fade" style="color: #555;">Cookies</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </footer>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
            if (typeof window.appAuthCache === 'undefined') {
               window.appAuthCache = null;
           }

function isUserLoggedIn() {
                if (window.appAuthCache !== null && window.appAuthCache.authenticated !== undefined) return Promise.resolve(window.appAuthCache);
                return fetch('/Account/CheckAuth')
                    .then(r => r.json())
                    .then(data => {
                        window.appAuthCache = data;
                        if (data.authenticated && data.userEmail) {
                            localStorage.setItem('userEmail', data.userEmail);
                        }
                        return data;
                    })
                    .catch(() => ({ authenticated: false, isAdmin: false }));
            }

 function updateUserLoginLink() {
                isUserLoggedIn().then(data => {
                    const loggedIn = data.authenticated;
                    const isAdmin = data.isAdmin;
                    const loginLinks = document.querySelectorAll('#userLoginLink, #userLoginLinkDesktop');
                    loginLinks.forEach(loginLink => {
                        if (loggedIn) {
                            loginLink.innerHTML = '<i class="bi bi-person-circle"></i>';
                            loginLink.title = isAdmin ? 'Admin Panel' : 'Account';
                            loginLink.href = isAdmin ? '/Admin/Dashboard' : '/Account/Profile';
                            loginLink.onclick = null;
                        } else {
                            loginLink.innerHTML = '<i class="bi bi-person"></i>';
                            loginLink.title = 'Login';
                            loginLink.href = '/Account/Login';
                            loginLink.onclick = null;
                        }
                    });
                });
            }

          function updateCartCount() {
              fetch('/Cart/GetCount')
                  .then(response => response.json())
                   .then(data => {
                       const cartBadge = document.querySelector('#cartLink .badge-count');
                       if (cartBadge) {
                           cartBadge.textContent = data.count;
                       }
                   });
           }

           function updateBookmarkCount() {
               fetch('/Bookmark/GetCount')
                   .then(response => response.json())
                   .then(data => {
                       const bookmarkBadge = document.querySelector('#bookmarkLink .badge-count');
                       const bookmarkIcon = document.querySelector('#bookmarkLink .bookmark-icon');
                       if (bookmarkBadge) {
                           bookmarkBadge.textContent = data.count;
                           if (data.count > 0) {
                               bookmarkBadge.style.display = 'inline-block';
                           } else {
                               bookmarkBadge.style.display = 'none';
                           }
                       }
                       if (bookmarkIcon) {
                           bookmarkIcon.style.color = data.count > 0 ? '#1a1a1a' : '#fff';
                       }
                   });
           }

function loginUser(email, password, rememberMe) {
               return fetch('/Account/LoginAjax', {
                   method: 'POST',
                   headers: {
                       'Content-Type': 'application/json',
                       'RequestVerificationToken': getAntiForgeryToken()
                   },
                   body: JSON.stringify({ email: email, password: password, rememberMe: rememberMe })
               })
               .then(response => response.json())
               .then(data => {
                   if (data.success) {
                       localStorage.setItem('authToken', 'fake-jwt-token');
                       localStorage.setItem('userEmail', email);
 window.appAuthCache = { authenticated: true, isAdmin: email === 'admin@represent.com' };
                         updateUserLoginLink();
                        updateCartCount();
                        updateBookmarkCount();
                       return true;
                   } else {
                       showError('Login failed: ' + (data.errors ? data.errors.join('. ') : 'Invalid credentials'));
                       return false;
                   }
               })
               .catch(error => {
                   showError('Network error: ' + error.message);
                   return false;
               });
           }

function logoutUser() {
               return fetch('/Account/LogoutAjax', {
                   method: 'POST',
                   headers: {
                       'Content-Type': 'application/json',
                       'RequestVerificationToken': getAntiForgeryToken()
                   }
               })
               .then(response => response.json())
               .then(data => {
                   if (data.success) {
                       window.appAuthCache = { authenticated: false, isAdmin: false };
                       localStorage.removeItem('authToken');
                       localStorage.removeItem('userEmail');
                        updateUserLoginLink();
                        updateCartCount();
                        updateBookmarkCount();
                        return true;
                   } else {
                       showError('Logout failed');
                       return false;
                   }
               })
               .catch(error => {
                   showError('Network error: ' + error.message);
                   return false;
               });
           }

          function getAntiForgeryToken() {
              const tokenElement = document.querySelector('[name=__RequestVerificationToken]');
              return tokenElement ? tokenElement.value : '';
          }

          function showError(message) {
              alert(message);
          }

           function toggleSearch() {
                const wrap = document.getElementById('searchWrap');
                const btn = document.getElementById('searchToggle');
                const input = document.getElementById('searchInput');
                const suggestions = document.getElementById('searchSuggestions');
                if (!wrap || !btn || !input) return;
                const opening = !wrap.classList.contains('open');
                wrap.classList.toggle('open', opening);
                if (opening) {
                    input.focus();
                } else {
                    input.value = '';
                    if (suggestions) suggestions.style.display = 'none';
                }
                btn.innerHTML = opening
                    ? '<i class="bi bi-x-lg" style="font-size: 0.95rem;"></i>'
                    : '<i class="bi bi-search" style="font-size: 0.95rem;"></i>';
            }

            document.getElementById('searchToggle').addEventListener('click', function (e) {
                e.preventDefault();
                toggleSearch();
            });

            document.getElementById('searchForm').addEventListener('submit', function () {
                const input = document.getElementById('searchInput');
                const suggestions = document.getElementById('searchSuggestions');
                if (!input || !input.value.trim()) {
                    if (suggestions) suggestions.style.display = 'none';
                }
            });

            let searchDebounce = null;
            document.getElementById('searchInput').addEventListener('input', function () {
                const q = this.value.trim();
                const suggestions = document.getElementById('searchSuggestions');
                if (!suggestions) return;
                if (!q) {
                    suggestions.style.display = 'none';
                    suggestions.innerHTML = '';
                    return;
                }
                clearTimeout(searchDebounce);
                searchDebounce = setTimeout(() => {
                    fetch('/Home/GetSuggestions?q=' + encodeURIComponent(q))
                        .then(r => r.json())
                        .then(data => {
                            if (!data || !data.length) {
                                suggestions.innerHTML = '<div class=\"no-results\">No results</div>';
                                suggestions.style.display = 'block';
                                return;
                            }
                            suggestions.innerHTML = data.map(item => {
                                const img = item.image ? `<img src=\"${item.image}\" alt=\"\" />` : '';
                                return `<a class=\"suggestion-item\" href=\"/Products/Details/${item.id}\">
                                    ${img}
                                    <div class=\"suggestion-meta\">
                                        <span class=\"suggestion-name\">${item.name}</span>
                                        <span class=\"suggestion-price\">$${Number(item.price).toFixed(2)}</span>
                                    </div>
                                </a>`;
                            }).join('');
                            suggestions.style.display = 'block';
                        })
                        .catch(() => {
                            suggestions.style.display = 'none';
                        });
                }, 180);
            });

            document.addEventListener('click', function (e) {
                const suggestions = document.getElementById('searchSuggestions');
                const searchWrap = document.getElementById('searchWrap');
                if (!suggestions || !searchWrap) return;
                if (!searchWrap.contains(e.target)) {
                    suggestions.style.display = 'none';
                }
            });

            document.addEventListener('DOMContentLoaded', function() {
                updateUserLoginLink();
                updateCartCount();
                updateBookmarkCount();
            });
      </script>
    @RenderSection("Scripts", required: false)

  </body>

</html>
