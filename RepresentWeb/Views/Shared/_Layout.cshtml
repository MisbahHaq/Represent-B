<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"] - RepresentWeb</title>
  <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/RepresentWeb.styles.css" asp-append-version="true" />
</head>

<style>
  .nav-small {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    line-height: 1;
  }
</style>

<body>
  <header>

    <nav class="navbar navbar-expand-lg navbar-dark bg-black border-bottom border-secondary py-3">
      <div class="container-fluid px-4 d-flex align-items-center justify-content-between">

         <!-- LEFT -->
        <div class="d-flex align-items-center gap-4">

          <a class="nav-link text-white text-uppercase p-0 nav-small" asp-controller="Home" asp-action="Men">
            Men
          </a>

          <a class="nav-link text-white text-uppercase p-0 nav-small" asp-controller="Home" asp-action="Women">
            Woman
          </a>

          <a class="nav-link text-white text-uppercase p-0 nav-small" asp-action="C247" asp-controller="Home">
            247
          </a>

        </div>

        <!-- CENTER -->
        <a class="navbar-brand position-absolute start-50 translate-middle-x text-white fw-semibold m-0"
           asp-action="Index" style="letter-spacing: 0.3em; font-size: 0.95rem;">
          REPRESENT
        </a>

        <!-- RIGHT -->
        <div class="d-flex align-items-center gap-4">

          <a class="nav-link text-white text-uppercase p-0 nav-small" asp-action="Retail" asp-controller="Home">
            Retail
          </a>

          <a class="nav-link text-white text-uppercase p-0 nav-small" asp-action="Vault" asp-controller="Home">
            The Vault
          </a>

          <a class="nav-link text-white text-uppercase p-0 nav-small" asp-action="Prestige" asp-controller="Home">
            Prestige
          </a>

          <a href="#" class="text-white">
            <i class="bi bi-search"></i>
          </a>

          <a href="#" class="text-white">
            <i class="bi bi-person"></i>
          </a>

          <a href="#" class="text-white position-relative">
            <i class="bi bi-bag"></i>

            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-light text-dark"
                  style="font-size: 0.45rem;">
              0
            </span>
          </a>

        </div>

      </div>
    </nav>

  </header>

  <main role="main" class="pb-3">
    @RenderBody()
  </main>

  <footer class="bg-black text-white border-top border-secondary">
    <div class="container py-5">
      <div class="row g-5">

        <!-- Logo + Newsletter -->
        <div class="col-lg-5">
          <h2 class="fw-semibold mb-4" style="letter-spacing: 0.3em;">
            REPRESENT
          </h2>

          <p class="text-secondary small mb-4" style="max-width: 400px; line-height: 1.8;">
            Sign up to receive exclusive access to new drops, restocks and
            members-only releases.
          </p>

          <form class="d-flex flex-column flex-sm-row gap-3">
            <input type="email" placeholder="Your email"
                   class="form-control bg-dark text-white border-secondary rounded-0" />

            <button class="btn btn-light rounded-0 px-4">
              Subscribe
            </button>
          </form>
        </div>

        <!-- Help -->
        <div class="col-6 col-md-3 col-lg-2">
          <h6 class="text-uppercase fw-bold mb-4">Help</h6>

          <ul class="list-unstyled d-flex flex-row gap-3 ">
            <li>
              <a href="#" class="text-secondary text-decoration-none">
                Contact
              </a>
            </li>

            <li>
              <a href="#" class="text-secondary text-decoration-none">
                Shipping
              </a>
            </li>

            <li>
              <a href="#" class="text-secondary text-decoration-none">
                Returns
              </a>
            </li>

            <li>
              <a href="#" class="text-secondary text-decoration-none">
                FAQs
              </a>
            </li>

            <li>
              <a href="#" class="text-secondary text-decoration-none">
                Privacy Policy
              </a>
            </li>
          </ul>
        </div>

        <!-- Bottom -->
        <div
          class="border-top border-secondary mt-5 pt-4 d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
          <p class="text-secondary small mb-0">
            © 2026 REPRESENT. All rights reserved.
          </p>

          <div class="d-flex gap-4">
            <a href="#" class="text-secondary text-decoration-none small">
              Terms
            </a>

            <a href="#" class="text-secondary text-decoration-none small">
              Privacy
            </a>

            <a href="#" class="text-secondary text-decoration-none small">
              Cookies
            </a>
          </div>
        </div>
      </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

  </body>

</html>
