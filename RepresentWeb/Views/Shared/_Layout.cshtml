<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"] - RepresentWeb</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght=200;300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/RepresentWeb.styles.css" asp-append-version="true" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
  @RenderSection("Head", required: false)
</head>

<style>
  .nav-link-minimal {
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #fff;
    text-decoration: none;
    padding: 0;
    opacity: 0.75;
    transition: opacity 0.5s ease;
  }
  .nav-link-minimal:hover { opacity: 1; color: #fff; }
  
  .badge-count {
    font-size: 0.6rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    padding: 0.3em 0.55em;
    border-radius: 0;
    background: #1a1a1a;
    color: #fff;
    min-width: 18px;
    text-align: center;
    line-height: 1;
  }
  
  .icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    opacity: 0.75;
    transition: opacity 0.5s ease;
    color: #fff;
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
  }
  .icon-btn:hover { opacity: 1; color: #fff; }

  #searchWrap {
    display: flex;
    align-items: center;
    overflow: hidden;
    max-width: 0;
    transition: max-width 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.25s ease;
    opacity: 0;
  }
  #searchWrap.open {
    max-width: 220px;
    opacity: 1;
  }
  #searchWrap input {
    width: 200px;
    font-size: 0.75rem;
    border: 0 !important;
    border-bottom: 0 !important;
    border-radius: 0 !important;
    background: rgba(255,255,255,0.1);
    color: #fff;
    outline: none !important;
    box-shadow: none !important;
    padding: 0 !important;
    height: 32px !important;
    line-height: 32px !important;
  }
  #searchWrap input:focus {
    border: 0 !important;
    border-bottom: 0 !important;
    box-shadow: none !important;
  }
  #searchWrap input::placeholder { color: rgba(255,255,255,0.5); }
  
  .minimal-line-input {
    background: transparent !important;
    border: none !important;
    border-bottom: 0 !important;
    border-radius: 0 !important;
    color: #fff !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    box-shadow: none !important;
    transition: border-color 0.3s ease;
  }
  .minimal-line-input:focus {
    border-bottom-color: transparent !important;
  }

  .mobile-search-box {
    border-bottom: 0 !important;
  }

  @@media (max-width: 575.98px) {
    #searchWrap { max-width: 150px; }
    #searchWrap.open { max-width: 150px; }
    #searchWrap input { width: 150px; font-size: 0.7rem; }
    
    #navbarContent,
    #navbarContent .d-flex.flex-column.flex-lg-row {
      align-items: flex-start !important;
      justify-content: flex-start !important;
      text-align: left !important;
      padding-left: 0.5rem !important;
      padding-right: 0.5rem !important;
    }

    #navbarContent > div > div:first-child {
      padding-top: 1.5rem !important;
    }
    
    .navbar-collapse {
      margin-top: 0 !important;
      padding-top: 0 !important;
    }
    
    .navbar-toggler {
      margin-top: 0 !important;
      margin-bottom: 0 !important;
    }
    
    .navbar-brand {
      font-size: 0.72rem !important;
      letter-spacing: 0.25em !important;
    }
  }

  #searchSuggestions, #searchSuggestionsMobileInner {
    position: absolute;
    top: 100%;
    right: 0;
    left: auto;
    width: 260px;
    background: #111;
    border: 1px solid #333;
    z-index: 1050;
    max-height: 320px;
    overflow-y: auto;
  }

  #searchSuggestionsMobileInner {
    left: 0;
    right: 0;
    width: 100%;
    position: relative;
    top: 0;
    border-top: none;
  }
  
  @@media (max-width: 991.98px) {
    #searchWrap { max-width: 100%; }
    #searchWrap.open { max-width: 100%; }
    #searchWrap input { width: 100%; font-size: 0.75rem; }
    #searchSuggestions { width: 100%; }
  }

  .suggestion-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.85rem;
    color: #ccc;
    text-decoration: none;
    font-size: 0.78rem;
    border-bottom: 1px solid #1f1f1f;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .suggestion-item:last-child { border-bottom: none; }
  .suggestion-item:hover { background: #1a1a1a; color: #fff; }
  .suggestion-item img {
    width: 36px;
    height: 36px;
    object-fit: cover;
    border-radius: 0;
    flex-shrink: 0;
    background: #222;
  }
  .suggestion-meta { display: flex; flex-direction: column; line-height: 1.3; }
  .suggestion-name { color: #fff; font-weight: 400; letter-spacing: 0.04em; }
  .suggestion-price { color: #888; font-size: 0.7rem; }
  .no-results { padding: 0.75rem 0.85rem; color: #666; font-size: 0.75rem; font-style: italic; }

  .related-swiper { overflow: hidden; }
  .related-swiper .swiper-slide { height: auto; }
  @@media (max-width: 575.98px) {
    .related-swiper .swiper-slide { flex: 0 0 50%; max-width: 50%; }
  }
  .swiper-button-next, .swiper-button-prev { color: #fff; }

  .chatbot-widget {
    position: fixed;
    right: 18px;
    bottom: 18px;
    z-index: 1080;
  }

  .chatbot-toggle {
    width: 58px;
    height: 58px;
    border: 0;
    border-radius: 999px;
    background: #111;
    color: #fff;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    box-shadow: 0 14px 35px rgba(0,0,0,0.22);
  }

  .chatbot-panel {
    position: fixed;
    right: 18px;
    bottom: 88px;
    width: min(390px, calc(100vw - 32px));
    max-height: min(680px, calc(100vh - 118px));
    display: none;
    flex-direction: column;
    overflow: hidden;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.12);
    box-shadow: 0 24px 70px rgba(0,0,0,0.22);
  }

  .chatbot-panel.open {
    display: flex;
  }

  .chatbot-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 16px;
    background: #111;
    color: #fff;
  }

  .chatbot-header strong {
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .chatbot-close {
    width: 30px;
    height: 30px;
    border: 0;
    background: transparent;
    color: #fff;
    cursor: pointer;
    font-size: 1.2rem;
    line-height: 1;
  }

  .chatbot-messages {
    flex: 1;
    min-height: 260px;
    max-height: 360px;
    overflow-y: auto;
    padding: 14px;
    background: #f8f7f4;
  }

  .chatbot-message {
    max-width: 86%;
    margin-bottom: 10px;
    padding: 10px 12px;
    border-radius: 14px;
    font-size: 0.82rem;
    line-height: 1.45;
    white-space: pre-wrap;
  }

  .chatbot-message.bot {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.08);
  }

  .chatbot-message.user {
    margin-left: auto;
    background: #111;
    color: #fff;
  }

  .chatbot-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 10px;
    border-top: 1px solid rgba(0,0,0,0.08);
    background: #fff;
  }

  .chatbot-action {
    border: 1px solid rgba(0,0,0,0.14);
    background: transparent;
    color: #111;
    cursor: pointer;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 8px 9px;
  }

  .chatbot-context-form {
    display: none;
    flex-direction: column;
    gap: 8px;
    padding: 10px;
    border-top: 1px solid rgba(0,0,0,0.08);
    background: #fff;
  }

  .chatbot-context-form.open {
    display: flex;
  }

  .chatbot-context-form input,
  .chatbot-context-form textarea {
    width: 100%;
    border: 1px solid rgba(0,0,0,0.14);
    border-radius: 0;
    padding: 9px 10px;
    font-size: 0.82rem;
  }

  .chatbot-context-form textarea {
    min-height: 76px;
    resize: vertical;
  }

  .chatbot-submit {
    border: 0;
    background: #111;
    color: #fff;
    cursor: pointer;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 10px;
  }

  @@media (max-width: 575.98px) {
    .chatbot-widget {
      right: 12px;
      bottom: 12px;
    }

    .chatbot-panel {
      right: 12px;
      bottom: 82px;
      width: calc(100vw - 24px);
    }

    .chatbot-toggle {
      width: 54px;
      height: 54px;
      font-size: 0.66rem;
    }
  }
</style>

<body>
  <div style="display:none">
    @Html.AntiForgeryToken()
  </div>
  <header>
    <nav class="navbar navbar-expand-lg navbar-dark bg-black border-bottom border-secondary py-2">
      <div class="container-fluid px-3 px-md-4 position-relative d-flex align-items-center justify-content-between">

        <button class="navbar-toggler border-0 shadow-none p-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation" style="z-index: 11; margin: 0 !important; padding: 0 !important; border: 0 !important;">
          <span class="navbar-toggler-icon"></span>
        </button>

        <a class="navbar-brand position-absolute start-50 translate-middle-x text-white m-0"
           style="letter-spacing: 0.35em; font-size: 0.78rem; font-weight: 200; text-transform: uppercase; z-index: 20; cursor: pointer;" asp-controller="Home" asp-action="Index">
          Represent
        </a>

        <div class="d-lg-none d-flex align-items-center" style="gap: 0.25rem; z-index: 11;">
          <a href="#" class="icon-btn" id="userLoginLinkMobile">
            <i class="bi bi-person" style="font-size: 0.95rem; color: #fff;"></i>
          </a>
          <a asp-controller="Cart" asp-action="Index" class="icon-btn position-relative" id="cartLinkMobile">
            <i class="bi bi-bag" style="font-size: 0.95rem;"></i>
            <span class="badge-count position-absolute" style="top: -2px; right: -4px;">0</span>
          </a>
        </div>

        <div class="collapse navbar-collapse w-100 mt-0 mt-lg-0 px-0" id="navbarContent" style="z-index: 10;">
          <div class="d-flex flex-column flex-lg-row align-items-stretch align-items-lg-center justify-content-between w-100 gap-2 pt-0">
            
            <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center gap-3 gap-lg-4 pt-0 pt-lg-0">
              <div class="d-lg-none w-100 my-0">
                <form asp-controller="Home" asp-action="Search" method="get" id="searchFormMobileInner" class="d-flex align-items-center mobile-search-box" style="border-bottom: 0 !important; position:relative;">
                  <input type="text" name="q" id="searchInputMobileInner" class="form-control minimal-line-input" placeholder="Search products..." autocomplete="off" style="flex-grow: 1;" />
                  <!-- <button type="submit" class="icon-btn" style="width: auto; height: auto; padding: 0.5rem;">
                    <i class="bi bi-search" style="font-size: 0.85rem;"></i>
                  </button> -->
                </form>
                <div id="searchSuggestionsMobileInner" style="display: none;"></div>
              </div>
              
              <a class="nav-link-minimal" asp-controller="Home" asp-action="Men">Men</a>
              <a class="nav-link-minimal" asp-controller="Home" asp-action="Women">Women</a>
              <a class="nav-link-minimal d-lg-none" asp-controller="Home" asp-action="Vault">The Vault</a>

              <a class="nav-link-minimal d-lg-none" asp-controller="Bookmark" asp-action="Index" id="bookmarkLinkMobileDrawer">
                Bookmarks <span class="badge-count ms-1" style="display: none;">0</span>
              </a>
            </div>

            <div class="d-none d-lg-flex align-items-center gap-4">
              <a class="nav-link-minimal" asp-action="Vault" asp-controller="Home">The Vault</a>

              <div class="d-flex align-items-center" style="position: relative;">
                <button type="button" class="icon-btn" id="searchToggle" aria-label="Search">
                  <i class="bi bi-search" style="font-size: 0.95rem;"></i>
                </button>

                <div id="searchWrap">
                  <form asp-controller="Home" asp-action="Search" method="get" id="searchForm" class="d-flex align-items-center ms-2">
                    <input type="text" name="q" id="searchInput" class="form-control" placeholder="Search..." autocomplete="off" />
                  </form>
                  <div id="searchSuggestions" style="display: none;"></div>
                </div>
              </div>

              <a href="#" class="icon-btn" id="userLoginLink">
                <i class="bi bi-person" style="font-size: 0.95rem; color: #fff;"></i>
              </a>

              <a asp-controller="Bookmark" asp-action="Index" class="icon-btn position-relative" id="bookmarkLink">
                <i class="bi bi-bookmark bookmark-icon" style="font-size: 0.95rem; color: #fff;"></i>
                <span class="badge-count position-absolute" style="top: -4px; right: -6px; display: none;">0</span>
              </a>

              <a asp-controller="Cart" asp-action="Index" class="icon-btn position-relative" id="cartLink">
                <i class="bi bi-bag" style="font-size: 0.95rem;"></i>
                <span class="badge-count position-absolute" style="top: -2px; right: -4px;">0</span>
              </a>
            </div>
            
          </div>
        </div>

      </div>
    </nav>
  </header>

  <div class="chatbot-widget" id="chatbotWidget">
    <div class="chatbot-panel" id="chatbotPanel" aria-hidden="true">
      <div class="chatbot-header">
        <strong>Represent Assistant</strong>
        <button type="button" class="chatbot-close" id="chatbotClose" aria-label="Close chatbot">×</button>
      </div>

      <div class="chatbot-messages" id="chatbotMessages" aria-live="polite">
        <div class="chatbot-message bot">Hi, I can check order status, send a cancellation request to admin, or notify admin to chat.</div>
      </div>

      <div class="chatbot-actions">
        <button type="button" class="chatbot-action" data-chatbot-mode="status">Order Status</button>
        <button type="button" class="chatbot-action" data-chatbot-mode="cancel">Cancel Order</button>
        <button type="button" class="chatbot-action" data-chatbot-mode="admin">Chat With Admin</button>
      </div>

      <form id="chatbotStatusForm" class="chatbot-context-form">
        <input id="chatbotStatusOrder" type="text" placeholder="Order number, e.g. 12" autocomplete="off" />
        <button type="submit" class="chatbot-submit">Check Status</button>
      </form>

      <form id="chatbotCancelForm" class="chatbot-context-form">
        <input id="chatbotCancelOrder" type="text" placeholder="Order number, e.g. 12" autocomplete="off" />
        <textarea id="chatbotCancelReason" placeholder="Cancellation reason"></textarea>
        <button type="submit" class="chatbot-submit">Send Cancellation Request</button>
      </form>

      <form id="chatbotAdminForm" class="chatbot-context-form">
        <input id="chatbotCustomerName" type="text" placeholder="Your name" autocomplete="name" />
        <input id="chatbotCustomerEmail" type="email" placeholder="Email" autocomplete="email" />
        <input id="chatbotAdminOrder" type="text" placeholder="Order number, optional" autocomplete="off" />
        <textarea id="chatbotAdminMessage" placeholder="Message for admin"></textarea>
        <button type="submit" class="chatbot-submit">Notify Admin</button>
      </form>
    </div>

    <button type="button" class="chatbot-toggle" id="chatbotToggle" aria-label="Open chatbot">Chat</button>
  </div>

  <main role="main" class="pb-0">
    @RenderBody()
    @RenderSection("Scripts", required: false)
  </main>

  <footer class="bg-dark text-white" style="padding-top: 5rem; padding-bottom: 3rem;">
    <div class="container-fluid px-4 px-lg-5" style="max-width: 1400px;">
      <div class="row g-4 gx-0" style="border-top: 1px solid #222; padding-top: 3rem;">

        <div class="col-12 col-lg-4 mb-4 mb-lg-0">
          <h2 class="m-0 mb-4" style="font-size: 0.85rem; font-weight: 200; letter-spacing: 0.35em; text-transform: uppercase;">
            Represent
          </h2>
          <p class="m-0" style="max-width: 340px; font-size: 0.8rem; font-weight: 300; color: #777; line-height: 1.8; letter-spacing: 0.03em;">
            Sign up to receive exclusive access to new drops, restocks and members-only releases.
          </p>
        </div>

        <div class="col-6 col-lg-2 offset-lg-1">
          <p class="text-caption mb-3" style="color: #555;">Help</p>
          <ul class="list-unstyled" style="font-size: 0.78rem; font-weight: 300; color: #888; line-height: 2.2;">
            <li><a href="#" class="text-decoration-none" style="color: #888;">Contact</a></li>
            <li><a href="#" class="text-decoration-none" style="color: #888;">Shipping</a></li>
            <li><a href="#" class="text-decoration-none" style="color: #888;">Returns</a></li>
            <li><a href="#" class="text-decoration-none" style="color: #888;">FAQs</a></li>
          </ul>
        </div>

        <div class="col-6 col-lg-2">
          <p class="text-caption mb-3" style="color: #555;">Connect</p>
          <ul class="list-unstyled" style="font-size: 0.78rem; font-weight: 300; color: #888; line-height: 2.2;">
            <li><a href="#" class="text-decoration-none" style="color: #888;">Instagram</a></li>
            <li><a href="#" class="text-decoration-none" style="color: #888;">Twitter / X</a></li>
            <li><a href="#" class="text-decoration-none" style="color: #888;">YouTube</a></li>
          </ul>
        </div>

        <div class="col-12 mt-5 pt-4">
          <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <p class="text-caption m-0" style="color: #444; font-size:0.75rem;">© 2026 Represent. All rights reserved.</p>
            <div class="d-flex gap-4" style="font-size:0.75rem;">
              <a href="#" class="text-decoration-none" style="color: #555;">Terms</a>
              <a href="#" class="text-decoration-none" style="color: #555;">Privacy</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </footer>

  <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
  <script>
    if (typeof window.appAuthCache === 'undefined') {
       window.appAuthCache = null;
    }

    function isUserLoggedIn() {
        if (window.appAuthCache !== null && window.appAuthCache.authenticated !== undefined) return Promise.resolve(window.appAuthCache);
        return fetch('/Account/CheckAuth')
            .then(r => r.json())
            .then(data => {
                window.appAuthCache = data;
                if (data.authenticated && data.userEmail) {
                    localStorage.setItem('userEmail', data.userEmail);
                }
                return data;
            })
            .catch(() => ({ authenticated: false, isAdmin: false }));
    }

    function updateUserLoginLink() {
        isUserLoggedIn().then(data => {
            const loggedIn = data.authenticated;
            const isAdmin = data.isAdmin;
            const loginLinks = document.querySelectorAll('#userLoginLink, #userLoginLinkMobile');
            
            loginLinks.forEach(loginLink => {
                if (loggedIn) {
                    loginLink.innerHTML = '<i class="bi bi-person-circle" style="font-size: 0.95rem; color: #fff;"></i>';
                    loginLink.title = isAdmin ? 'Admin Panel' : 'Account';
                    loginLink.href = isAdmin ? '/Admin/Dashboard' : '/Account/Profile';
                } else {
                    loginLink.innerHTML = '<i class="bi bi-person" style="font-size: 0.95rem; color: #fff;"></i>';
                    loginLink.title = 'Login';
                    loginLink.href = '/Account/Login';
                }
            });
        });
    }

    function updateCartCount() {
      fetch('/Cart/GetCount')
          .then(response => response.json())
           .then(data => {
               const cartBadges = document.querySelectorAll('#cartLink .badge-count, #cartLinkMobile .badge-count');
               cartBadges.forEach(badge => {
                   if (badge) badge.textContent = data.count;
               });
           });
    }

    function updateBookmarkCount() {
       fetch('/Bookmark/GetCount')
           .then(response => response.json())
           .then(data => {
                const desktopBadge = document.querySelector('#bookmarkLink .badge-count');
                const mobileDrawerBadge = document.querySelector('#bookmarkLinkMobileDrawer .badge-count');
               
                if (desktopBadge) {
                    desktopBadge.textContent = data.count;
                    desktopBadge.style.display = data.count > 0 ? 'inline-block' : 'none';
                }
                if (mobileDrawerBadge) {
                    mobileDrawerBadge.textContent = data.count;
                    mobileDrawerBadge.style.display = data.count > 0 ? 'inline-block' : 'none';
                }
           });
    }

    function initChatbot() {
      const panel = document.getElementById('chatbotPanel');
      const toggle = document.getElementById('chatbotToggle');
      const close = document.getElementById('chatbotClose');
      const messages = document.getElementById('chatbotMessages');
      const forms = Array.from(document.querySelectorAll('.chatbot-context-form'));
      let activeMode = '';

      if (!panel || !toggle || !messages) return;

      function addMessage(text, sender) {
        const message = document.createElement('div');
        message.className = 'chatbot-message ' + (sender || 'bot');
        message.textContent = text;
        messages.appendChild(message);
        messages.scrollTop = messages.scrollHeight;
      }

      function showMode(mode) {
        activeMode = mode;
        forms.forEach(form => form.classList.toggle('open', form.id === 'chatbot' + mode.charAt(0).toUpperCase() + mode.slice(1) + 'Form'));
        addMessage(mode === 'status' ? 'Enter the order number and I will check its status.' : mode === 'cancel' ? 'Enter the order number and cancellation reason. Admin will review it.' : 'Enter your details and message. Admin will be notified.', 'bot');
      }

      function clearMode() {
        activeMode = '';
        forms.forEach(form => form.classList.remove('open'));
      }

      function getVerificationToken() {
        return document.querySelector('[name=__RequestVerificationToken]')?.value || '';
      }

      function postChatbot(url, payload) {
        return fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'RequestVerificationToken': getVerificationToken()
          },
          body: JSON.stringify(payload)
        }).then(response => response.json());
      }

      toggle.addEventListener('click', function() {
        const isOpen = panel.classList.toggle('open');
        panel.setAttribute('aria-hidden', String(!isOpen));
        toggle.textContent = isOpen ? 'Close' : 'Chat';
        if (isOpen) {
          const input = panel.querySelector('input, textarea');
          input?.focus();
        }
      });

      close.addEventListener('click', function() {
        panel.classList.remove('open');
        panel.setAttribute('aria-hidden', 'true');
        toggle.textContent = 'Chat';
        clearMode();
      });

      document.querySelectorAll('[data-chatbot-mode]').forEach(button => {
        button.addEventListener('click', function() {
          showMode(this.dataset.chatbotMode);
        });
      });

      document.getElementById('chatbotStatusForm').addEventListener('submit', function(event) {
        event.preventDefault();
        const orderNumber = document.getElementById('chatbotStatusOrder').value.trim();
        if (!orderNumber) {
          addMessage('Please enter an order number.', 'bot');
          return;
        }
        addMessage('Order #' + orderNumber, 'user');
        postChatbot('/Chatbot/Status', { orderNumber }).then(data => {
          addMessage(data.message || 'Something went wrong.', data.success ? 'bot' : 'user');
        });
      });

      document.getElementById('chatbotCancelForm').addEventListener('submit', function(event) {
        event.preventDefault();
        const orderNumber = document.getElementById('chatbotCancelOrder').value.trim();
        const reason = document.getElementById('chatbotCancelReason').value.trim();
        if (!orderNumber || !reason) {
          addMessage('Please enter both order number and cancellation reason.', 'bot');
          return;
        }
        addMessage('Cancel order #' + orderNumber + ': ' + reason, 'user');
        postChatbot('/Chatbot/Cancel', { orderNumber, reason }).then(data => {
          addMessage(data.message || 'Something went wrong.', data.success ? 'bot' : 'user');
        });
      });

      document.getElementById('chatbotAdminForm').addEventListener('submit', function(event) {
        event.preventDefault();
        const customerName = document.getElementById('chatbotCustomerName').value.trim();
        const customerEmail = document.getElementById('chatbotCustomerEmail').value.trim();
        const orderNumber = document.getElementById('chatbotAdminOrder').value.trim();
        const message = document.getElementById('chatbotAdminMessage').value.trim();
        if (!message) {
          addMessage('Please enter a message for admin.', 'bot');
          return;
        }
        addMessage(message, 'user');
        postChatbot('/Chatbot/NotifyAdmin', { customerName, customerEmail, orderNumber, message }).then(data => {
          addMessage(data.message || 'Something went wrong.', data.success ? 'bot' : 'user');
        });
      });

      fetch('/Account/CheckAuth')
        .then(response => response.json())
        .then(data => {
          if (data.authenticated && data.userEmail) {
            document.getElementById('chatbotCustomerEmail').value = data.userEmail;
            document.getElementById('chatbotCustomerName').value = data.userName || 'Customer';
          }
        })
        .catch(() => {});
    }

    function getAntiForgeryToken() {
      const tokenElement = document.querySelector('[name=__RequestVerificationToken]');
      return tokenElement ? tokenElement.value : '';
    }

    function toggleSearch() {
         const wrap = document.getElementById('searchWrap');
         const btn = document.getElementById('searchToggle');
         const input = document.getElementById('searchInput');
         const suggestions = document.getElementById('searchSuggestions');
         if (!wrap || !btn || !input) return;
         const opening = !wrap.classList.contains('open');
         wrap.classList.toggle('open', opening);
         if (opening) {
             input.focus();
         } else {
             input.value = '';
             if (suggestions) suggestions.style.display = 'none';
         }
         btn.innerHTML = opening
             ? '<i class="bi bi-x-lg" style="font-size: 0.95rem;"></i>'
             : '<i class="bi bi-search" style="font-size: 0.95rem;"></i>';
    }

    if(document.getElementById('searchToggle')) {
        document.getElementById('searchToggle').addEventListener('click', function (e) {
            e.preventDefault();
            toggleSearch();
        });
    }

    // Helper function for building unified dynamic autocomplete results
    function bindSearchAutocomplete(inputElementId, suggestionsElementId) {
        const inputEl = document.getElementById(inputElementId);
        const suggestEl = document.getElementById(suggestionsElementId);
        if(!inputEl || !suggestEl) return;

        let debounce = null;
        inputEl.addEventListener('input', function() {
            const q = this.value.trim();
            if(!q) {
                suggestEl.style.display = 'none';
                suggestEl.innerHTML = '';
                return;
            }
            clearTimeout(debounce);
            debounce = setTimeout(() => {
                fetch('/Home/GetSuggestions?q=' + encodeURIComponent(q))
                    .then(r => r.json())
                    .then(data => {
                        if (!data || !data.length) {
                            suggestEl.innerHTML = '<div class="no-results">No results</div>';
                            suggestEl.style.display = 'block';
                            return;
                        }
                        suggestEl.innerHTML = data.map(item => {
                            const img = item.image ? `<img src="${item.image}" alt="" />` : '';
                            return `<a class="suggestion-item" href="/Products/Details/${item.id}">
                                ${img}
                                <div class="suggestion-meta">
                                    <span class="suggestion-name">${item.name}</span>
                                    <span class="suggestion-price">$${Number(item.price).toFixed(2)}</span>
                                </div>
                            </a>`;
                        }).join('');
                        suggestEl.style.display = 'block';
                    })
                    .catch(() => { suggestEl.style.display = 'none'; });
            }, 180);
        });
    }

    document.addEventListener('DOMContentLoaded', function() {
        updateUserLoginLink();
        updateCartCount();
        updateBookmarkCount();
        initChatbot();
        
        // Bind live query listeners to both elements cleanly
        bindSearchAutocomplete('searchInput', 'searchSuggestions');
        bindSearchAutocomplete('searchInputMobileInner', 'searchSuggestionsMobileInner');
    });

    document.addEventListener('click', function (e) {
        ['searchSuggestions', 'searchSuggestionsMobileInner'].forEach(id => {
            const el = document.getElementById(id);
            if(el && !el.contains(e.target) && e.target.id !== 'searchInput' && e.target.id !== 'searchInputMobileInner') {
                el.style.display = 'none';
            }
        });
    });
  </script>
</body>
</html>